class HistoryManagerWindow(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent, Qt.Tool | Qt.FramelessWindowHint)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self.setFixedSize(760, 480)
        self._sel_sid       = ""
        self._session_widgets: Dict[str, QWidget] = {}
        self._drag_pos      = None
        self._build()
        sc = QApplication.primaryScreen().geometry()
        self.move((sc.width() - self.width()) // 2, (sc.height() - self.height()) // 2 - 40)

    def _build(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(16, 16, 16, 16); root.setSpacing(10)

        hdr = QHBoxLayout()
        title = QLabel("Chat History")
        title.setFont(QFont("Segoe UI Semibold", 13))
        title.setStyleSheet("color: #00F0FF; background: transparent;")
        hdr.addWidget(title)
        hdr.addStretch()
        close_btn = QPushButton("✕")
        close_btn.setFixedSize(26, 26)
        close_btn.setStyleSheet("""
            QPushButton { background: rgba(80,0,0,180); color: #FF4040;
                border: 1px solid rgba(255,60,60,80); border-radius: 7px; font-weight: bold; }
            QPushButton:hover { background: rgba(120,0,0,220); border: 1px solid rgb(255,80,80); color: #FFFFFF; }
            QPushButton:pressed { background: rgba(180,0,0,240); }
        """)
        close_btn.clicked.connect(self.hide)
        hdr.addWidget(close_btn)
        root.addLayout(hdr)

        splitter = QSplitter(Qt.Horizontal)
        splitter.setStyleSheet("QSplitter::handle { background: rgba(0,200,255,30); width: 2px; }")

        # Sessions list
        left = QWidget(); left.setFixedWidth(200)
        left.setStyleSheet("background: transparent;")
        ll = QVBoxLayout(left)
        ll.setContentsMargins(0, 0, 0, 0); ll.setSpacing(6)
        sess_lbl = QLabel("Sessions")
        sess_lbl.setFont(QFont("Segoe UI", 9))
        sess_lbl.setStyleSheet("color: #406080; background: transparent;")
        ll.addWidget(sess_lbl)
        self._sess_scroll = QScrollArea()
        self._sess_scroll.setWidgetResizable(True)
        self._sess_scroll.setStyleSheet("""
            QScrollArea { border: none; background: transparent; }
            QScrollBar:vertical { background: rgba(0,20,30,80); width: 4px; border-radius: 2px; }
            QScrollBar::handle:vertical { background: rgba(0,240,255,140); border-radius: 2px; }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
        """)
        self._sess_container = QWidget()
        self._sess_container.setStyleSheet("background: transparent;")
        self._sess_lay = QVBoxLayout(self._sess_container)
        self._sess_lay.setContentsMargins(0, 0, 0, 0)
        self._sess_lay.setSpacing(4); self._sess_lay.addStretch()
        self._sess_scroll.setWidget(self._sess_container)
        ll.addWidget(self._sess_scroll)
        splitter.addWidget(left)

        # Transcript
        right = QWidget()
        right.setStyleSheet("background: transparent;")
        rl = QVBoxLayout(right)
        rl.setContentsMargins(8, 0, 0, 0); rl.setSpacing(6)
        self._session_title = QLabel("Select a session…")
        self._session_title.setFont(QFont("Segoe UI", 9))
        self._session_title.setStyleSheet("color: #406080; background: transparent;")
        rl.addWidget(self._session_title)
        self._transcript = QTextEdit()
        self._transcript.setReadOnly(True)
        self._transcript.setFont(QFont("Segoe UI", 9))
        self._transcript.setStyleSheet("""
            QTextEdit { background: rgba(4,8,20,200); color: #A0C8E0;
                border: 1px solid rgba(0,160,200,50); border-radius: 8px; padding: 8px; }
            QScrollBar:vertical { background: rgba(0,10,20,80); width: 4px; border-radius: 2px; }
            QScrollBar::handle:vertical { background: rgba(0,200,255,100); border-radius: 2px; }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
        """)
        rl.addWidget(self._transcript)

        btn_row = QHBoxLayout()
        for lbl, fn in [("Clear Session", self._clear_session),
                         ("Clear All", self._clear_all)]:
            b = QPushButton(lbl)
            b.setStyleSheet("""
                QPushButton { background: rgba(40,0,0,180); color: #FF6060;
                    border: 1px solid rgba(200,40,40,80); border-radius: 7px;
                    padding: 4px 12px; font-weight: bold; }
                QPushButton:hover { background: rgba(80,0,0,220); border: 1px solid rgb(255,80,80); color: #FFFFFF; }
                QPushButton:pressed { background: rgba(120,0,0,240); }
            """)
            b.clicked.connect(fn)
            btn_row.addWidget(b)
        btn_row.addStretch()
        rl.addLayout(btn_row)
        splitter.addWidget(right)
        splitter.setSizes([200, 540])
        root.addWidget(splitter)

    def _load_sessions(self):
        self._session_widgets.clear()
        while self._sess_lay.count() > 1:
            item = self._sess_lay.takeAt(0)
            if item and item.widget():
                item.widget().deleteLater()
        sessions = _HIST.get_all_sessions()
        for s in reversed(sessions):
            sid  = s["session_id"]
            n    = len(s.get("entries", []))
            btn  = QPushButton(f"{s.get('date',sid)}  ({n})")
            btn.setFont(QFont("Segoe UI", 8))
            btn.setStyleSheet("""
                QPushButton { background: rgba(0,20,35,180); color: #6090B0;
                    border: 1px solid rgba(0,120,180,50); border-radius: 6px;
                    padding: 4px 8px; text-align: left; }
                QPushButton:hover { background: rgba(0,40,60,200); color: #00F0FF; border: 1px solid rgb(0,240,255); }
                QPushButton:pressed { background: rgba(0,60,90,240); }
            """)
            btn.clicked.connect(lambda _, _sid=sid: self._on_session_clicked(_sid))
            self._sess_lay.insertWidget(0, btn)
            self._session_widgets[sid] = btn

    def _on_session_clicked(self, sid: str):
        self._sel_sid = sid
        session = _HIST.get_session(sid)
        if not session:
            self._transcript.clear(); return
        entries = session.get("entries", [])
        n = len(entries)
        self._session_title.setText(
            f"Session: {session.get('date', sid)} — {n} exchange(s)")
        self._transcript.clear()
        for entry in entries:
            ts  = entry.get("ts", "")[:19].replace("T", " ")
            usr = html.escape(entry.get("user", ""))
            ish = html.escape(entry.get("isha", ""))
            self._transcript.append(
                f'<span style="color:#305868;">[{ts}]</span> '
                f'<span style="color:#5090A8;"><b>You:</b></span> '
                f'<span style="color:#8BBAC8;">{usr}</span>')
            self._transcript.append(
                f'<span style="color:#206050;"><b>ISHA:</b></span> '
                f'<span style="color:#70A090;">{ish}</span><br>')
        sb = self._transcript.verticalScrollBar()
        QTimer.singleShot(50, lambda: sb.setValue(sb.maximum()))

    def _clear_session(self):
        if not self._sel_sid:
            CyberpunkDialog.info(self, "No Selection", "Please select a session first.")
            return
        if CyberpunkDialog.confirm(self, "Clear Session",
                                    f"Delete all entries in session '{self._sel_sid}'?"):
            _HIST.clear_session(self._sel_sid)
            self._sel_sid = ""; self._transcript.clear()
            self._session_title.setText("Session cleared.")
            self._load_sessions()

    def _clear_all(self):
        if CyberpunkDialog.confirm(self, "Clear ALL History",
                "This will permanently delete ALL conversation history. Continue?"):
            _HIST.clear_all()
            self._sel_sid = ""; self._transcript.clear()
            self._session_title.setText("All history cleared.")
            self._load_sessions()
            CyberpunkDialog.success(self, "Done", "All chat history has been cleared.")

    def refresh(self):
        prev_sid = self._sel_sid
        self._load_sessions()
        if prev_sid and prev_sid in self._session_widgets:
            self._on_session_clicked(prev_sid)

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()

    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)

    def mouseReleaseEvent(self, e):
        self._drag_pos = None

    def showEvent(self, e):
        super().showEvent(e); self._load_sessions()

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 16, 16)
        bg = QLinearGradient(0, 0, W, H)
        bg.setColorAt(0.0, QColor(4,  8, 20, 254))
        bg.setColorAt(0.5, QColor(7, 12, 28, 254))
        bg.setColorAt(1.0, QColor(4,  8, 20, 254))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 160), 2.0))
        p.setBrush(Qt.NoBrush); p.drawPath(path)
        sheen = QPainterPath()
        sheen.addRoundedRect(QRectF(2, 2, W - 4, 32), 14, 14)
        p.fillPath(sheen, QColor(255, 255, 255, 4))
        pen = QPen(QColor(0, 240, 255, 100), 1.5); p.setPen(pen)
        for (x, y, dx, dy) in [(1,1,14,0),(1,1,0,14),(W-1,1,-14,0),(W-1,1,0,14),
                                 (1,H-1,14,0),(1,H-1,0,-14),(W-1,H-1,-14,0),(W-1,H-1,0,-14)]:
            p.drawLine(x, y, x + dx, y + dy)



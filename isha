_MD_STRIP_RE    = re.compile(r'[*_#`~\[\]>|\\]')
_HTML_TAG_RE    = re.compile(r'<[^>]+>')
_EMOJI_RE       = re.compile(
    "["
    u"\U0001F600-\U0001F64F"
    u"\U0001F300-\U0001F5FF"
    u"\U0001F680-\U0001F6FF"
    u"\U0001F1E0-\U0001F1FF"
    u"\U00002702-\U000027B0"
    u"\U000024C2-\U0001F251"
    "]+", flags=re.UNICODE
)
_MULTI_SPACE_RE = re.compile(r'  +')


def _sanitize_for_tts(text: str) -> str:
    t = html.unescape(text)
    t = _HTML_TAG_RE.sub(' ', t)
    t = _MD_STRIP_RE.sub('', t)
    t = _EMOJI_RE.sub('', t)
    t = re.sub(r'^\s*[\-•·◦▸►]\s*', ' ', t, flags=re.MULTILINE)
    t = re.sub(r'^\s*\d+[\.\)]\s*', ' ', t, flags=re.MULTILINE)
    t = _MULTI_SPACE_RE.sub(' ', t).strip()
    return t


class EdgeTTSWorker(QThread):
    """
    Dedicated QThread owning an asyncio event loop for edge-tts.
    Consumes text from a thread-safe queue.
    Never touches any Qt widget; communicates via pyqtSignal only.
    """
    tts_error = pyqtSignal(str)

    VOICE = "en-IN-NeerjaNeural"   # Premium Indian-English female voice

    def __init__(self):
        super().__init__()
        self.setObjectName("ISHA-EdgeTTS")
        # QThread is automatically a daemon thread when parent app exits
        self._q        = queue.Queue()
        self._alive    = True
        self._loop     = None
        self._disabled = False
        self._volume   = 65  # Default volume percentage
        self._is_speaking = False

    def set_volume(self, val: int):
        """Update TTS voice volume (0-100%)."""
        self._volume = max(0, min(100, val))

    def run(self):
        self._loop = asyncio.new_event_loop()
        asyncio.set_event_loop(self._loop)
        try:
            self._loop.run_until_complete(self._consume_loop())
        finally:
            self._loop.close()

    async def _consume_loop(self):
        while self._alive:
            try:
                text = await self._loop.run_in_executor(
                    None, lambda: self._q.get(timeout=0.4))
            except queue.Empty:
                continue
            if text is None:
                break
            if not text.strip():
                continue
            await self._speak_async(text)

    @staticmethod
    def _play_silent(tmp_path: str, volume: int = 65):
        """
        Play an MP3 silently — NO media player window opens ever.
        Tries: pygame.mixer -> playsound 1.2.2 -> winmm ctypes -> afplay -> mpg123/ffplay
        Runs synchronously (called inside a daemon thread by _speak_async).
        """
        # 1. pygame.mixer — best choice: truly windowless, accurate EOF
        try:
            import pygame
            if not pygame.get_init():
                pygame.init()
            if not pygame.mixer.get_init():
                pygame.mixer.init(frequency=44100, size=-16, channels=2, buffer=512)
            pygame.mixer.music.load(tmp_path)
            pygame.mixer.music.set_volume(volume / 100.0)
            pygame.mixer.music.play()
            while pygame.mixer.music.get_busy():
                time.sleep(0.05)
            try:
                pygame.mixer.music.unload()
            except Exception:
                pass
            return
        except Exception:
            pass

        # 2. playsound 1.2.2 — stable, windowless on Windows
        try:
            from playsound import playsound
            playsound(tmp_path, block=True)
            return
        except Exception:
            pass

        # 3. Windows-only: winmm via ctypes — zero GUI footprint
        if sys.platform == "win32":
            try:
                import ctypes
                winmm = ctypes.WinDLL("winmm.dll")
                alias = "isha_tts_out"
                winmm.mciSendStringW(f'open "{tmp_path}" type mpegvideo alias {alias}', None, 0, None)
                winmm.mciSendStringW(f"play {alias} wait", None, 0, None)
                winmm.mciSendStringW(f"close {alias}", None, 0, None)
                return
            except Exception:
                pass

        # 4. macOS afplay — native, windowless
        if sys.platform == "darwin":
            try:
                subprocess.run(["afplay", tmp_path],
                               stdout=subprocess.DEVNULL,
                               stderr=subprocess.DEVNULL)
                return
            except Exception:
                pass

        # 5. Linux fallback — mpg123 / ffplay hidden
        for player in ("mpg123", "ffplay", "aplay"):
            try:
                cf = subprocess.CREATE_NO_WINDOW if sys.platform == "win32" else 0
                subprocess.run(
                    [player, tmp_path],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    creationflags=cf,
                )
                return
            except FileNotFoundError:
                continue

    async def _speak_async(self, text: str):
        self._is_speaking = True
        try:
            import edge_tts, tempfile, os as _os
            vol_str = f"{self._volume - 100}%" if self._volume < 100 else "+0%"
            communicate = edge_tts.Communicate(text, self.VOICE, volume=vol_str)
            with tempfile.NamedTemporaryFile(
                    suffix=".mp3", delete=False) as tmp:
                tmp_path = tmp.name
            try:
                await communicate.save(tmp_path)
                # Run blocking playback on a daemon thread so the asyncio
                # event loop stays alive; await join via executor so the
                # loop blocks on *this* speech before queuing the next one
                # (prevents overlapping utterances).
                play_thread = threading.Thread(
                    target=self._play_silent,
                    args=(tmp_path, self._volume),
                    daemon=True,
                    name="ISHA-AudioPlay",
                )
                play_thread.start()
                await self._loop.run_in_executor(None, play_thread.join)
            finally:
                try:
                    _os.unlink(tmp_path)
                except Exception:
                    pass
        except ImportError:
            if not self._disabled:
                self._disabled = True
                print("[TTS] edge-tts not installed — voice disabled.")
        except Exception as exc:
            print(f"[TTS] speak error: {exc}")
        finally:
            self._is_speaking = False

    def is_speaking(self) -> bool:
        return getattr(self, "_is_speaking", False)

    def speak(self, raw_text: str):
        if not raw_text or not self._alive or self._disabled:
            return
        clean = _sanitize_for_tts(raw_text)
        if clean:
            # Drain stale items (interrupt old speech)
            while True:
                try:
                    self._q.get_nowait()
                except queue.Empty:
                    break
            self._q.put(clean)

    def shutdown(self):
        self._alive = False
        self._q.put(None)
        self.wait(3000)


# ── Module-level TTS singleton ─────────────────────────────────────────────
_TTS = EdgeTTSWorker()

# Dedup guard
_last_spoken      : str   = ""
_last_spoken_time : float = 0.0
_speak_lock = threading.Lock()


def speak(text: str) -> None:
    """THE sole gateway for all ISHA voice output."""
    global _last_spoken, _last_spoken_time
    if not text:
        return
    clean = _sanitize_for_tts(text)
    if not clean:
        return
    now = time.monotonic()
    with _speak_lock:
        if clean == _last_spoken and (now - _last_spoken_time) < 1.0:
            return
        _last_spoken      = clean
        _last_spoken_time = now
    print(f"[ISHA ▶] {clean[:120]}")
    _TTS.speak(clean)
    try:
        _comm_log(f"ISHA ▶ {text[:120]}")
    except NameError:
        pass  # CommDock not constructed yet


class TTSBridge(QObject):
    """Qt signal bridge: any thread can emit speak_signal(text) safely."""
    speak_signal = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self.speak_signal.connect(self._on_speak, Qt.QueuedConnection)

    def _on_speak(self, text: str):
        speak(text)

    def request_speak(self, text: str):
        self.speak_signal.emit(text)


_TTS_BRIDGE = TTSBridge()


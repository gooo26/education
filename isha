def _extract_city(text: str) -> str:
    tl = text.lower()
    m = re.search(
        r"(?:weather|temperature|temp|forecast)\s+(?:in|at|for)\s+"
        r"([a-zA-Z\s]+?)(?:\?|$|please|today|now)", tl)
    if m:
        return m.group(1).strip().title()
    m2 = re.search(r"([a-zA-Z\s]{3,})\s+(?:weather|temperature|temp|forecast)", tl)
    if m2:
        city = m2.group(1).strip()
        skip = {"what is the", "what is", "tell me", "current", "today",
                "check", "show", "how is the", "how is"}
        if city.lower() not in skip and len(city) > 2:
            return city.title()
    return ""


def _weather_sync(query: str = "") -> str:
    city    = _extract_city(query) or DEFAULT_CITY
    api_key = _API_STORE.get("openweather", WEATHER_API_KEY_DEFAULT)
    try:
        import requests
        url  = (f"https://api.openweathermap.org/data/2.5/weather"
                f"?q={city}&appid={api_key}&units=metric")
        resp = requests.get(url, timeout=8)
        data = resp.json()
        if str(data.get("cod")) != "200":
            errmsg = data.get("message", "City not found")
            return (f"Weather data unavailable for '{city}': {errmsg}. "
                    f"Try: 'weather in Delhi'.")
        desc    = data["weather"][0]["description"].capitalize()
        temp    = data["main"]["temp"]
        feels   = data["main"]["feels_like"]
        humidity= data["main"]["humidity"]
        wind    = round(data["wind"]["speed"] * 3.6, 1)
        return (f"Weather in {data['name']}, {data['sys']['country']}: {desc}. "
                f"Temp: {temp}°C, feels like {feels}°C. "
                f"Humidity: {humidity}%. Wind: {wind} km/h.")
    except ImportError:
        return "requests is not installed."
    except Exception as exc:
        return f"Could not fetch weather: {exc}"



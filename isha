        yes_btn.clicked.connect(d.accept); no_btn.clicked.connect(d.reject)
        row.addWidget(yes_btn); row.addWidget(no_btn)
        lay.addLayout(row)
        return d.exec_() == QDialog.Accepted

    @staticmethod
    def success(parent, title: str, msg: str):

class SandboxWorker(QThread):
    """
    Runs the most recently modified file in ISHA_Workspace in a
    sandboxed subprocess. Streams every line of stdout + stderr live to
    the CommDock log.  Emits finished(result_summary) when process ends.
    """
    log_signal = pyqtSignal(str)   # Each stdout/stderr line → CommDock
    finished   = pyqtSignal(str)   # Done summary message

    def __init__(self, filepath: str, parent=None):
        super().__init__(parent)
        self._filepath = filepath

    @staticmethod
    def get_latest_workspace_file(ext: Optional[str] = None) -> Optional[str]:
        """Return the most recently modified file in Workspace, optionally filtered by extension."""
        wdir = os.path.join(os.path.expanduser("~"), "Desktop", "ISHA_Workspace")
        if not os.path.isdir(wdir):
            return None
        candidates = [
            os.path.join(wdir, f)
            for f in os.listdir(wdir)
            if os.path.isfile(os.path.join(wdir, f)) and (ext is None or f.lower().endswith(ext))
        ]
        if not candidates:
            return None
        return max(candidates, key=os.path.getmtime)

    def run(self):
        _CF = subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0
        self.log_signal.emit(f"[SANDBOX] Executing: {os.path.basename(self._filepath)}")
        try:
            ext = os.path.splitext(self._filepath)[1].lower()
            if ext == ".py":
                cmd = [sys.executable, self._filepath]
            elif ext == ".js":
                cmd = ["node", self._filepath]
            elif ext in (".bat", ".cmd"):
                cmd = [self._filepath]
            elif ext == ".ps1":
                cmd = ["powershell", "-ExecutionPolicy", "Bypass", "-File", self._filepath]
            else:
                if ext in (".html", ".htm"):
                    if os.name == "nt":
                        os.startfile(self._filepath)
                    else:
                        subprocess.Popen(["xdg-open", self._filepath])
                    summary = f"Opened HTML file '{os.path.basename(self._filepath)}' in the browser, Boss."
                    self.log_signal.emit(f"[SANDBOX] {summary}")
                    self.finished.emit(summary)
                    return
                cmd = [self._filepath]

            proc = subprocess.Popen(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                encoding="utf-8",
                errors="replace",
                creationflags=_CF,
            )

            output_lines: List[str] = []
            output_lock = threading.Lock()

            def read_stream(stream, prefix):
                try:
                    for line in iter(stream.readline, ''):
                        if not line:
                            break
                        line = line.rstrip()
                        self.log_signal.emit(f"{prefix} {line}")
                        with output_lock:
                            output_lines.append(line)
                            if len(output_lines) > 500:   # safety cap
                                break
                except Exception as e:
                    self.log_signal.emit(f"[SANDBOX READER ERROR] {e}")

            t_out = threading.Thread(target=read_stream, args=(proc.stdout, "[SANDBOX OUT]"), daemon=True)
            t_err = threading.Thread(target=read_stream, args=(proc.stderr, "[SANDBOX ERR]"), daemon=True)
            t_out.start()
            t_err.start()

            proc.wait(timeout=60)
            t_out.join(timeout=1.0)
            t_err.join(timeout=1.0)

            rc = proc.returncode
            summary = (
                f"Done Boss! '{os.path.basename(self._filepath)}' finished "
                f"(exit code {rc}). "
                + ("Check CommDock for output." if output_lines else "No output produced.")
            )
        except subprocess.TimeoutExpired:
            proc.kill()
            summary = f"Sandbox timeout! '{os.path.basename(self._filepath)}' took too long — process killed."
        except Exception as exc:
            summary = f"Sandbox error: {exc}"
        self.log_signal.emit(f"[SANDBOX] {summary}")
        self.finished.emit(summary)


# Keep a registry so GC doesn't kill running sandbox workers
_active_sandbox_workers: List[SandboxWorker] = []
_sandbox_worker_lock = threading.Lock()


def _launch_sandbox_worker(filepath: str) -> None:
    """Spin up SandboxWorker for the given file path."""
    worker = SandboxWorker(filepath)

    def _on_done(result: str):
        speak(result)
        _comm_log(f"[SANDBOX DONE] {result[:120]}")
        with _sandbox_worker_lock:
            try:
                _active_sandbox_workers.remove(worker)
            except ValueError:
                pass

    worker.finished.connect(_on_done, Qt.QueuedConnection)
    worker.log_signal.connect(_comm_log, Qt.QueuedConnection)
    with _sandbox_worker_lock:
        _active_sandbox_workers.append(worker)
    worker.start()


class OSAgentEngine:
    """
    Stateless engine.  Call OSAgentEngine.execute(action_dict, log_fn).
    Returns a human-readable string describing what happened.
    """

    # ── Main dispatcher ────────────────────────────────────────────────────
    @staticmethod
    def execute(action: dict, log: Callable[[str], None] = print) -> str:
        category = action.get("category", "")
        details  = action.get("action_details", {})
        log(f"[AGENT] Executing {category}: {str(details)[:120]}")
        if category == "CODE_CREATION":
            return OSAgentEngine._code_creation(details, log)
        if category == "OS_CONTROL":
            return OSAgentEngine._os_control(details, log)
        if category == "BROWSER_CONTROL":
            return OSAgentEngine._browser_control(details, log)
        if category == "FILE_SEARCH":
            return OSAgentEngine._file_search(details, log)
        return f"Unknown agent category: {category}"

    # ── CODE_CREATION ──────────────────────────────────────────────────────
    @staticmethod
    def _code_creation(d: dict, log: Callable) -> str:
        lang     = d.get("language", "python").lower()
        filename = d.get("filename", "isha_generated.py")
        code     = d.get("code", "")
        desc     = d.get("description", "Generated code")

        if not code:
            return "No code was generated."

        # Sanitise filename
        filename = re.sub(r'[<>:"/\\|?*]', "_", filename)
        path = _workspace_path(filename)

        # FIX: shared no-window flag for every Popen below
        _CF = subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0

        try:
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w", encoding="utf-8") as f:
                f.write(code)
            log(f"[AGENT] Saved {filename} → {path}")
        except Exception as exc:
            return f"Failed to save file: {exc}"

        # Try to run/open based on language — NO console windows ever visible
        try:
            if lang in ("python", "py"):
                # NEW_CONSOLE replaced with hidden window flags
                subprocess.Popen(
                    ["python", path],
                    creationflags=_CF,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                log(f"[AGENT] Running: python {filename}")
            elif lang in ("html", "javascript", "js", "css"):
                if os.name == "nt":
                    os.startfile(path)
                else:
                    subprocess.Popen(
                        ["xdg-open", path],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                    )
                log(f"[AGENT] Opened in browser: {filename}")
            elif lang in ("batch", "bat", "cmd"):
                subprocess.Popen(
                    [path],
                    shell=True,
                    creationflags=_CF,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                log(f"[AGENT] Running batch: {filename}")
            elif lang in ("powershell", "ps1"):
                subprocess.Popen(
                    ["powershell", "-ExecutionPolicy", "Bypass",
                     "-WindowStyle", "Hidden", "-File", path],
                    creationflags=_CF,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                log(f"[AGENT] Running PowerShell: {filename}")
            else:
                if os.name == "nt":
                    os.startfile(path)
                else:
                    subprocess.Popen(
                        ["xdg-open", path],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                    )
        except Exception as exc:
            log(f"[AGENT] Run failed: {exc}")
            return f"Code saved to Workspace as '{filename}' but could not be run: {exc}"

        return (
            f"Done! I created '{filename}' ({desc}) and launched it in your Workspace. "
            f"Full path: {path}"
        )

    # ── OS_CONTROL ─────────────────────────────────────────────────────────
    @staticmethod
    def _os_control(d: dict, log: Callable) -> str:
        cmd = d.get("command", "").upper()
        log(f"[AGENT] OS command: {cmd}")

        try:
            if cmd == "LOCK_PC":
                if os.name == "nt":
                    import ctypes
                    ctypes.windll.user32.LockWorkStation()
                return "Workstation locked."

            if cmd == "SHUTDOWN":
                if os.name == "nt":
                    subprocess.run(["shutdown", "/s", "/t", "10"], check=True)
                else:
                    subprocess.run(["shutdown", "-h", "+1"], check=True)
                return "Shutting down in 10 seconds. Say 'cancel shutdown' to abort."

            if cmd == "RESTART":
                if os.name == "nt":
                    subprocess.run(["shutdown", "/r", "/t", "10"], check=True)
                else:
                    subprocess.run(["reboot"], check=True)
                return "Restarting in 10 seconds."

            if cmd == "EMPTY_BIN":
                if os.name == "nt":
                    import ctypes
                    # SHERB_NOCONFIRMATION=1, SHERB_NOPROGRESSUI=2, SHERB_NOSOUND=4
                    ctypes.windll.shell32.SHEmptyRecycleBinW(None, None, 0x0007)
                    return "Recycle Bin emptied."
                return "Recycle Bin emptying is Windows-only."

            if cmd == "SLEEP":
                if os.name == "nt":
                    import ctypes
                    ctypes.windll.PowrProf.SetSuspendState(0, 1, 0)
                return "Going to sleep."

            if cmd == "HIBERNATE":
                if os.name == "nt":
                    subprocess.run(["shutdown", "/h"], check=True)
                return "Hibernating."

            if cmd == "TASK_MANAGER":
                if os.name == "nt":
                    subprocess.Popen("taskmgr")
                return "Task Manager opened."

            if cmd == "CONTROL_PANEL":
                if os.name == "nt":
                    subprocess.Popen("control")
                return "Control Panel opened."

            if cmd in ("MUTE", "UNMUTE", "VOL_UP", "VOL_DOWN"):
                try:
                    import pyautogui
                    key_map = {
                        "MUTE": "volumemute",
                        "UNMUTE": "volumemute",
                        "VOL_UP": "volumeup",
                        "VOL_DOWN": "volumedown",
                    }
                    pyautogui.press(key_map[cmd])
                    return f"Volume command '{cmd}' sent."
                except ImportError:
                    return "pyautogui is required for volume control."

            if cmd == "SCREENSHOT":
                try:
                    import pyautogui
                    fname = _desktop_path(
                        f"screenshot_{datetime.now().strftime('%Y%m%d_%H%M%S')}.png"
                    )
                    pyautogui.screenshot(fname)
                    return f"Screenshot saved to Desktop: {os.path.basename(fname)}"
                except ImportError:
                    return "pyautogui is required for screenshot."

            if cmd == "CLIPBOARD_CLEAR":
                try:
                    import pyperclip
                    pyperclip.copy("")
                    return "Clipboard cleared."
                except ImportError:
                    if os.name == "nt":
                        subprocess.run(
                            'echo off | clip', shell=True, check=True)
                    return "Clipboard cleared."

            return f"Unknown OS command: {cmd}"

        except Exception as exc:
            log(f"[AGENT] OS_CONTROL error: {exc}")
            return f"OS command failed: {exc}"

    # ── BROWSER_CONTROL ────────────────────────────────────────────────────
    @staticmethod
    def _browser_control(d: dict, log: Callable) -> str:
        action  = d.get("action", "OPEN_URL").upper()
        url     = d.get("url", "")
        hotkey  = d.get("hotkey", "")
        log(f"[AGENT] Browser: {action} {url}")

        # Helper: find Chrome executable
        def _chrome_path() -> str:
            candidates = [
                r"C:\Program Files\Google\Chrome\Application\chrome.exe",
                r"C:\Program Files (x86)\Google\Chrome\Application\chrome.exe",
                os.path.expandvars(
                    r"%LOCALAPPDATA%\Google\Chrome\Application\chrome.exe"),
            ]
            for c in candidates:
                if os.path.exists(c):
                    return c
            return "chrome"  # rely on PATH

        try:
            if action == "OPEN_URL":
                if url:
                    webbrowser.open(url)
                    return f"Opened: {url}"
                return "No URL specified."

            if action == "INCOGNITO":
                chrome = _chrome_path()
                target = url if url else "https://www.google.com"
                subprocess.Popen([chrome, "--incognito", target])
                return f"Opened incognito Chrome → {target}"

            if action in ("NEW_TAB", "CLOSE_TAB", "BACK", "FORWARD",
                          "REFRESH", "FULLSCREEN", "FIND_IN_PAGE",
                          "ZOOM_IN", "ZOOM_OUT") or hotkey:
                try:
                    import pyautogui, time as _t
                    key_map = {
                        "NEW_TAB":      "ctrl+t",
                        "CLOSE_TAB":    "ctrl+w",
                        "BACK":         "alt+left",
                        "FORWARD":      "alt+right",
                        "REFRESH":      "f5",
                        "FULLSCREEN":   "f11",
                        "FIND_IN_PAGE": "ctrl+f",
                        "ZOOM_IN":      "ctrl+=",
                        "ZOOM_OUT":     "ctrl+-",
                    }
                    combo = hotkey or key_map.get(action, "")
                    if combo:
                        _t.sleep(0.3)
                        pyautogui.hotkey(*combo.split("+"))
                        return f"Browser shortcut sent: {combo}"
                    return f"No hotkey mapping for: {action}"
                except ImportError:
                    return "pyautogui required for browser shortcuts."

            return f"Unknown browser action: {action}"

        except Exception as exc:
            log(f"[AGENT] BROWSER_CONTROL error: {exc}")
            return f"Browser command failed: {exc}"

    # ── FILE_SEARCH ────────────────────────────────────────────────────────
    @staticmethod
    def _file_search(d: dict, log: Callable) -> str:
        filename    = d.get("filename", "")
        drives      = d.get("drives", ["C", "D", "E"])
        open_folder = d.get("open_folder", True)

        if not filename:
            return "No filename specified."

        fname_lower = filename.lower()
        log(f"[AGENT] Searching for '{filename}' on drives: {drives}")
        found: List[str] = []

        for drive in drives:
            root = f"{drive}:\\" if os.name == "nt" else f"/{drive}"
            if not os.path.exists(root):
                continue
            try:
                for dirpath, _, filenames in os.walk(root):
                    for fn in filenames:
                        if fn.lower() == fname_lower:
                            full = os.path.join(dirpath, fn)
                            found.append(full)
                            log(f"[AGENT] Found: {full}")
                            if len(found) >= 5:
                                break
                    if len(found) >= 5:
                        break
            except PermissionError:
                continue
            except Exception as exc:
                log(f"[AGENT] Walk error on {drive}: {exc}")

        if not found:
            return f"File '{filename}' not found on drives: {', '.join(drives)}."

        result_msg = f"Found {len(found)} match(es) for '{filename}':\n"
        for p in found:
            result_msg += f"  • {p}\n"

        if open_folder and found:
            folder = os.path.dirname(found[0])
            try:
                if os.name == "nt":
                    subprocess.Popen(f'explorer /select,"{found[0]}"', shell=True)
                else:
                    subprocess.Popen(["xdg-open", folder])
                log(f"[AGENT] Opened folder: {folder}")
            except Exception as exc:
                log(f"[AGENT] Open folder failed: {exc}")

        return result_msg.strip()


# ── Active AgentWorker registry (so GC doesn't kill them) ─────────────────
_active_agent_workers: List[AgentWorker] = []
_agent_worker_lock = threading.Lock()


def _launch_agent_worker(action: dict) -> None:
    """Spin up AgentWorker QThread and register it."""
    worker = AgentWorker(action)

    def _on_done(result: str):
        speak(result)
        _comm_log(f"[AGENT DONE] {result[:120]}")
        with _agent_worker_lock:
            try:
                _active_agent_workers.remove(worker)
            except ValueError:
                pass

    worker.finished.connect(_on_done, Qt.QueuedConnection)
    worker.log_signal.connect(_comm_log, Qt.QueuedConnection)

    with _agent_worker_lock:
        _active_agent_workers.append(worker)

    worker.start()


def _parse_agent_json(raw: str) -> Optional[dict]:
    """Extract and parse the ACTION JSON from an LLM reply. Returns None if not present."""
    # Try direct parse first
    stripped = raw.strip()
    if stripped.startswith("{"):
        try:
            obj = json.loads(stripped)
            if obj.get("type") == "ACTION" and obj.get("category") in _AGENT_CATEGORIES:
                return obj
        except json.JSONDecodeError:
            pass

    # Find JSON block inside longer text
    match = re.search(r'\{[\s\S]*?"type"\s*:\s*"ACTION"[\s\S]*?\}', raw)
    if match:
        try:
            obj = json.loads(match.group())
            if obj.get("type") == "ACTION" and obj.get("category") in _AGENT_CATEGORIES:
                return obj
        except json.JSONDecodeError:
            pass

    return None


# ── Active model state — persisted across runtime via JSON ─────────────────
# v15: Quick Settings → Models is now a strict RADIO-BUTTON GROUP. Exactly
# ONE local model is ever "ON" — every other model is implicitly "OFF".
# Boots with _DEFAULT_ACTIVE_MODEL (qwen2.5-coder:3b) selected.
_ACTIVE_MODEL_FILE = Path("isha_active_model.json")
_ACTIVE_MODEL_LOCK = threading.Lock()
_ACTIVE_MODEL: str = _DEFAULT_ACTIVE_MODEL


def _load_active_model() -> str:
    if _ACTIVE_MODEL_FILE.exists():
        try:
            data = json.loads(_ACTIVE_MODEL_FILE.read_text("utf-8"))
            name = data.get("active_model")
            if name:
                return name
        except Exception:
            pass
    return _DEFAULT_ACTIVE_MODEL


def _save_active_model():
    try:
        _ACTIVE_MODEL_FILE.write_text(
            json.dumps({"active_model": _ACTIVE_MODEL}, indent=2, ensure_ascii=False),
            "utf-8",
        )
    except Exception as exc:
        print(f"[MODEL_TOGGLE] Save failed: {exc}")


_ACTIVE_MODEL = _load_active_model()


def get_active_model() -> str:
    """Returns the single model currently ON in Quick Settings → Models."""
    with _ACTIVE_MODEL_LOCK:
        if "active_model" in REPLY_DB and REPLY_DB["active_model"]:
            val = REPLY_DB["active_model"]
            if isinstance(val, list) and val:
                return val[0]
            elif isinstance(val, str):
                return val
        return _ACTIVE_MODEL


def set_active_model(model_name: str):
    """
    Exclusively activates model_name — radio-button semantics. All other
    models become OFF the instant this is called, and the choice is
    persisted immediately so it survives restarts.
    """
    global _ACTIVE_MODEL
    with _ACTIVE_MODEL_LOCK:
        _ACTIVE_MODEL = model_name
        _save_active_model()
        REPLY_DB["active_model"] = [model_name]
    print(f"[MODEL_TOGGLE] Active model -> {model_name} (all others OFF)")


def is_model_enabled(model_name: str) -> bool:
    """True only for the single exclusive active model — every other model is OFF."""
    return get_active_model() == model_name


def set_model_enabled(model_name: str, enabled: bool):
    """
    Back-compat shim preserving the old call signature used around the
    codebase. Turning a model ON makes it the new exclusive active model
    (instantly flipping the previous one OFF). Turning the currently
    active model OFF directly is a no-op — a radio-button group always
    keeps exactly one option selected.
    """
    if enabled:
        set_active_model(model_name)



def _try_cloud_api(prompt: str,
                   history: Optional[List[dict]] = None) -> Optional[str]:
    """
    Route prompt to the first active cloud API config.

    FIX (v14):
    - Anthropic API is ALWAYS tried first regardless of config order.
      If ANY active config is Anthropic, it becomes the primary router.
    - Anthropic payload uses the strict v1/messages format:
        headers: x-api-key, anthropic-version, content-type
        body:    model, max_tokens, system, messages
      The system prompt is passed as a top-level "system" key (not inside
      messages) so Claude receives _AGENT_SYSTEM_PROMPT cleanly and can
      return ACTION JSON exactly as the _parse_agent_json() parser expects.
    - model upgraded to claude-3-5-sonnet-20241022 per requirements.
    - max_tokens bumped to 1024 so long CODE_CREATION payloads don't truncate.
    - All errors caught silently and returned as None so caller falls back
      to local Ollama.

    Returns a clean string response, or None if no active config / on error.
    """
    actives = _get_active_api_configs()
    if not actives:
        return None

    # ── Anthropic-first: sort so any Anthropic config leads ───────────────
    sorted_actives = sorted(
        actives,
        key=lambda c: 0 if c.get("vendor") == "Anthropic API" else 1
    )

    # Build conversation history (strip system messages — handled separately)
    messages_hist: List[dict] = []
    if history:
        for msg in history[-12:]:
            role = msg.get("role", "")
            if role in ("user", "assistant"):
                messages_hist.append({"role": role, "content": msg["content"]})

    try:
        import requests

        for cfg in sorted_actives:
            vendor  = cfg.get("vendor", "")
            api_key = cfg.get("key", "")
            _comm_log(f"[CLOUD] Routing to {vendor}")

            # ── ANTHROPIC API — PRIMARY ROUTER ─────────────────────────────
            if vendor == "Anthropic API":
                msgs = list(messages_hist) + [{"role": "user", "content": prompt}]
                try:
                    r = requests.post(
                        "https://api.anthropic.com/v1/messages",
                        headers={
                            "x-api-key":         api_key,
                            "anthropic-version": "2023-06-01",
                            "content-type":      "application/json",
                        },
                        json={
                            "model":      "claude-3-5-sonnet-20241022",
                            "max_tokens": 1024,
                            "system":     _AGENT_SYSTEM_PROMPT,
                            "messages":   msgs,
                        },
                        timeout=30,
                    )
                    r.raise_for_status()
                    data  = r.json()
                    reply = data["content"][0]["text"].strip()
                    _comm_log(f"[CLOUD Anthropic] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] Anthropic error: {exc}")
                    print(f"[CLOUD API] Anthropic error: {exc}")
                    # Fall through to next active config (if any)
                    continue

            # ── OPENAI ─────────────────────────────────────────────────────
            if vendor == "OpenAI":
                msgs = [{"role": "system", "content": _AGENT_SYSTEM_PROMPT}]
                msgs.extend(messages_hist)
                msgs.append({"role": "user", "content": prompt})
                try:
                    r = requests.post(
                        "https://api.openai.com/v1/chat/completions",
                        headers={"Authorization": f"Bearer {api_key}",
                                 "Content-Type": "application/json"},
                        json={"model": "gpt-4o-mini", "messages": msgs, "max_tokens": 512},
                        timeout=20)
                    r.raise_for_status()
                    reply = r.json()["choices"][0]["message"]["content"].strip()
                    _comm_log(f"[CLOUD OpenAI] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] OpenAI error: {exc}")
                    continue

            # ── GOOGLE GEMINI ───────────────────────────────────────────────
            if vendor == "Google Gemini":
                try:
                    r = requests.post(
                        f"https://generativelanguage.googleapis.com/v1beta/"
                        f"models/gemini-1.5-flash:generateContent?key={api_key}",
                        json={"contents": [{"parts": [{"text": _AGENT_SYSTEM_PROMPT + "\n\n" + prompt}]}],
                              "generationConfig": {"maxOutputTokens": 512}},
                        timeout=20)
                    r.raise_for_status()
                    data = r.json()
                    reply = (data.get("candidates", [{}])[0]
                             .get("content", {})
                             .get("parts", [{}])[0]
                             .get("text", "")).strip()
                    _comm_log(f"[CLOUD Gemini] {reply[:80]}")
                    return reply if reply else None
                except Exception as exc:
                    _comm_log(f"[CLOUD API] Gemini error: {exc}")
                    continue

            # ── GROQ ────────────────────────────────────────────────────────
            if vendor == "Groq API":
                msgs = [{"role": "system", "content": _AGENT_SYSTEM_PROMPT}]
                msgs.extend(messages_hist)
                msgs.append({"role": "user", "content": prompt})
                try:
                    r = requests.post(
                        "https://api.groq.com/openai/v1/chat/completions",
                        headers={"Authorization": f"Bearer {api_key}",
                                 "Content-Type": "application/json"},
                        json={"model": "llama-3.1-8b-instant", "messages": msgs, "max_tokens": 512},
                        timeout=20)
                    r.raise_for_status()
                    reply = r.json()["choices"][0]["message"]["content"].strip()
                    _comm_log(f"[CLOUD Groq] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] Groq error: {exc}")
                    continue

            # ── MISTRAL ─────────────────────────────────────────────────────
            if vendor == "Mistral AI":
                msgs = [{"role": "system", "content": _AGENT_SYSTEM_PROMPT}]
                msgs.extend(messages_hist)
                msgs.append({"role": "user", "content": prompt})
                try:
                    r = requests.post(
                        "https://api.mistral.ai/v1/chat/completions",
                        headers={"Authorization": f"Bearer {api_key}",
                                 "Content-Type": "application/json"},
                        json={"model": "mistral-small-latest", "messages": msgs, "max_tokens": 512},
                        timeout=20)
                    r.raise_for_status()
                    reply = r.json()["choices"][0]["message"]["content"].strip()
                    _comm_log(f"[CLOUD Mistral] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] Mistral error: {exc}")
                    continue

            # ── TOGETHER AI ─────────────────────────────────────────────────
            if vendor == "Together AI":
                msgs = [{"role": "system", "content": _AGENT_SYSTEM_PROMPT}]
                msgs.extend(messages_hist)
                msgs.append({"role": "user", "content": prompt})
                try:
                    r = requests.post(
                        "https://api.together.xyz/v1/chat/completions",
                        headers={"Authorization": f"Bearer {api_key}",
                                 "Content-Type": "application/json"},
                        json={"model": "meta-llama/Llama-3-8b-chat-hf",
                              "messages": msgs, "max_tokens": 512},
                        timeout=20)
                    r.raise_for_status()
                    reply = r.json()["choices"][0]["message"]["content"].strip()
                    _comm_log(f"[CLOUD Together] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] Together error: {exc}")
                    continue

            # ── DEEPSEEK ────────────────────────────────────────────────────
            if vendor == "DeepSeek API":
                msgs = [{"role": "system", "content": _AGENT_SYSTEM_PROMPT}]
                msgs.extend(messages_hist)
                msgs.append({"role": "user", "content": prompt})
                try:
                    r = requests.post(

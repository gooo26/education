        self._drag_pos = None
        self._build()

    def _build(self):
        self._root_lay = QVBoxLayout(self)
        self._root_lay.setContentsMargins(18, 18, 18, 18)
        self._root_lay.setSpacing(10)

        header = QLabel("<b style='color:#00F0FF; font-size:12pt;'>API Mode 🌐</b>")

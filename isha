def _is_math(text: str) -> bool:
    tl = text.strip().lower()
    for pfx in ("what is", "whats", "calculate", "solve", "compute",
                 "find value of", "evaluate", "answer of",
                 "tell me", "how much is", "how many"):
        tl = re.sub(r"^" + pfx + r"\b", "", tl).strip()
    if not tl:
        return False
    return bool(_MATH_RE.search(tl))




# ── Deterministic intent router (NO LLM GUESSING) ─────────────────────────
# v15.2 SAFETY FIX: this module previously fell back to _llm_classify_intent(),
# a *second*, separate tiny LLM call that tried to guess an intent label for
# any text that didn't match a deterministic keyword. That guesser was the
# root cause of the "routing loop" bug: plain conversational questions (e.g.
# "computer kese kam karat hai", "mujhe phone by karane ka hai") could be
# mis-labelled by the weak classifier as "system_info" / "screenshot" / etc,
# silently hijacking the reply with a RAM dump or a screenshot instead of a
# normal chat answer — even though the main chat LLM would have answered
# correctly. That guesser has been REMOVED entirely. classify_intent() now
# ONLY ever returns a non-"chat" intent when the user's text contains an
# explicit, whole-word/phrase match for a real command. Everything else —
# by design, with no exceptions — falls through to "chat", which routes to
# LocalAI.ask() for a normal conversational reply.

def _kw_match(tl: str, keyword: str) -> bool:
    """
    Strict whole-word/phrase match. Prevents the classic false-positive class
    where a short command keyword is merely a SUBSTRING of an unrelated word
    in normal conversation — e.g. "lock" inside "blockchain", "mute" inside
    "commute", "ip" inside "equip". Plain `keyword in text` containment is
    exactly the kind of fragile keyword fallback that causes accidental
    system actions, so every deterministic check below goes through this
    word-boundary-safe helper instead.
    """
    return re.search(r'\b' + re.escape(keyword) + r'\b', tl) is not None


_intent_cache: dict = {}
_intent_cache_lock = threading.Lock()


def classify_intent(text: str) -> str:
    """
    Strict, deterministic, whole-word intent classifier. No LLM is ever
    consulted here — only explicit, unambiguous keyword/phrase matches can
    produce a non-"chat" result. Anything else returns "chat" and is handed
    to the real conversational LLM in process_input().
    """
    tl = text.lower().strip()

    # Fast math pre-check (no LLM needed)
    if _is_math(tl):
        return "math"

    # Keyword fast-paths for ultra-common deterministic cases. Each keyword
    # is matched on whole-word/phrase boundaries via _kw_match — never a
    # raw substring check — to keep conversational text safe.
    for kw in ("take a screenshot", "capture screen", "screenshot"):
        if _kw_match(tl, kw):
            return "screenshot"
    for kw in ("what time", "current time", "what date", "today date", "what day"):
        if _kw_match(tl, kw):
            return "date_time"
    for kw in ("latest news", "top headlines", "breaking news", "news today"):
        if _kw_match(tl, kw):
            return "news"
    for kw in ("weather in", "weather today", "temperature", "forecast", "will it rain"):
        if _kw_match(tl, kw):
            return "weather"
    for kw in ("gaana bajao",):
        if _kw_match(tl, kw):
            return "play_youtube"
    if _kw_match(tl, "play") and any(_kw_match(tl, w) for w in ("youtube", "song", "music", "video")):
        return "play_youtube"
    for kw in ("my ip", "ip address", "internet speed", "speed test"):
        if _kw_match(tl, kw):
            return "ip_speed"
    for kw in ("my ram", "ram info", "how much ram", "cpu info", "disk space", "storage info"):
        if _kw_match(tl, kw):
            return "system_info"
    for kw in ("gateway", "mac address", "mac id", "physical address"):
        if _kw_match(tl, kw):
            return "network_info"
    for kw in ("set alarm", "alarm at", "alarm for", "wake me up", "remind me in"):
        if _kw_match(tl, kw):
            return "alarm"
    for kw in ("selfie", "webcam photo", "take my photo", "take picture"):
        if _kw_match(tl, kw):
            return "selfie"
    for kw in ("record screen", "screen record", "start recording"):
        if _kw_match(tl, kw):
            return "record_screen"
    for kw in ("volume up", "volume down", "mute", "unmute", "close window",
                "scroll up", "scroll down", "minimize", "alt tab"):
        if _kw_match(tl, kw):
            return "system_ctrl"
    for kw in ("open display", "open sound settings", "open wifi settings",
                "open bluetooth", "display settings"):
        if _kw_match(tl, kw):
            return "open_setting"
    for kw in ("search for", "search on google", "google search", "look up", "find information about"):
        if _kw_match(tl, kw):
            return "web_search"

    # Cache lookup (kept for parity with earlier behaviour / future callers)
    with _intent_cache_lock:
        if tl in _intent_cache:
            return _intent_cache[tl]

    # No deterministic match → this is conversation. Always "chat" — never
    # ask a model to guess, and never execute anything from here.
    intent = "chat"

    with _intent_cache_lock:
        _intent_cache[tl] = intent
        # Keep cache bounded
        if len(_intent_cache) > 500:
            keys = list(_intent_cache.keys())
            for k in keys[:100]:
                del _intent_cache[k]
    return intent



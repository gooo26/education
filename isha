def cmd_alarm(text: str) -> str:
    tl = text.lower()
    m  = re.search(r"(\d{1,2})[:\.](\d{2})\s*(am|pm)?", tl)
    if m:
        h, mn = int(m.group(1)), int(m.group(2))
        ampm  = (m.group(3) or "").lower()
        if ampm == "pm" and h < 12: h += 12
        elif ampm == "am" and h == 12: h = 0
        target = f"{h:02d}:{mn:02d}"
        def _alarm_thread():
            while True:
                if datetime.now().strftime("%H:%M") == target:
                    _async_respond(f"Alarm! It is {target}. Time to wake up!")
                    try:
                        import winsound
                        for _ in range(3):
                            winsound.Beep(1000, 600)
                            time.sleep(0.4)
                    except Exception:
                        pass
                    break
                time.sleep(20)
        threading.Thread(target=_alarm_thread, daemon=True).start()
        result = f"Alarm set for {target}."; speak(result); return result
    m2 = re.search(r"(\d+)\s*(hour|hr|minute|min|second|sec)", tl)
    if m2:
        n, unit = int(m2.group(1)), m2.group(2)
        secs  = n * (3600 if "h" in unit else 60 if "m" in unit else 1)
        label = (f"{n} {'hour' if 'h' in unit else 'minute' if 'm' in unit else 'second'}"
                 f"{'s' if n > 1 else ''}")
        threading.Thread(
            target=lambda: (time.sleep(secs),
                            _async_respond(f"Reminder! {label} are up.")),
            daemon=True).start()
        result = f"Reminder set for {label} from now."
        speak(result); return result
    result = "Please say something like 'alarm 07:30' or '10 minute reminder'."
    speak(result); return result



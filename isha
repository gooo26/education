def _missing_packages() -> list:
    """Checks for required Python packages, including mediapipe."""
    required = ["PyQt5", "pyautogui", "requests", "psutil", "edge_tts", "opencv-python", "mediapipe"]
    missing = []
    for pkg in required:
        try:
            # Handle opencv naming convention mapping
            import_name = "cv2" if pkg == "opencv-python" else pkg
            __import__(import_name)
        except ImportError:
            missing.append(pkg)
    return missing

def _missing_models() -> list:
    """
    Single-model sync (v15): the installer now only ever checks for and
    pulls the one default local model — qwen2.5-coder:3b — instead of
    waiting on several heavy models before ISHA can launch.

    Returns [] if qwen2.5-coder:3b is already pulled, otherwise
    [_DEFAULT_ACTIVE_MODEL] so the InstallerDialog queues exactly one pull.
    """
    target = _DEFAULT_ACTIVE_MODEL
    try:
        import ollama as _ol
        resp   = _ol.list()
        models = resp.models if hasattr(resp, "models") else resp.get("models", [])
        present: set = set()
        for m in models:
            name = (m.model if hasattr(m, "model") else
                    m.get("name", m.get("model", "")))
            if name:
                present.add(name.strip())
        return [] if target in present else [target]
    except Exception:
        # Ollama not installed / not running yet — assume the model still
        # needs to be pulled so the installer can fetch it.
        return [target]


def _self_install():
    """Quietly install missing pip packages and pull missing Ollama models.

    FIX (v14):
    - All subprocess calls use CREATE_NO_WINDOW on Windows + DEVNULL pipes
      so zero console windows ever appear.
    - Ollama server/model operations wrapped in try/except so an unreachable
      Ollama daemon fails silently and never blocks startup.
    """
    print("[ISHA] Self-install check starting…")

    # ── Shared subprocess flags ────────────────────────────────────────────
    _CF = subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0

    # ── 1. Pip packages ────────────────────────────────────────────────────
    for pkg in _PIP_PACKAGES:
        import_name = pkg.replace("-", "_").split("[")[0]
        _import_map = {
            "PyQt5": "PyQt5",
            "edge_tts": "edge_tts",
            "SpeechRecognition": "speech_recognition",
            "beautifulsoup4": "bs4",
            "opencv_python": "cv2",
            "speedtest_cli": "speedtest",
            "pywhatkit": "pywhatkit",
        }
        import_name = _import_map.get(import_name, import_name)
        try:
            __import__(import_name)
        except ImportError:
            print(f"[INSTALL] Installing {pkg}…")
            try:
                subprocess.check_call(
                    [sys.executable, "-m", "pip", "install", pkg,
                     "--quiet", "--disable-pip-version-check"],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    creationflags=_CF,          # ← NO console window
                )
                print(f"[INSTALL] {pkg} installed.")
            except Exception as e:
                print(f"[INSTALL] WARNING: could not install {pkg}: {e}")

    # ── 2. Ollama model puller ─────────────────────────────────────────────
    # Entire block wrapped so an offline/missing Ollama never blocks startup.
    try:
        import ollama as _ol

        # Check which models are already present (quiet fail if server is down)
        try:
            resp   = _ol.list()
            models = resp.models if hasattr(resp, "models") else resp.get("models", [])
            present_full: set = set()   # exact "name:tag" matches
            present_base: set = set()   # bare name (no tag) matches
            for m in models:
                name = (m.model if hasattr(m, "model") else
                        m.get("name", m.get("model", "")))
                if name:
                    name = name.strip()
                    present_full.add(name)
                    present_base.add(name.split(":")[0])
        except Exception:
            # Ollama daemon not running or not installed — skip silently
            present_full, present_base = set(), set()

        for model in _OLLAMA_MODELS:
            has_tag = ":" in model
            already = (model in present_full) if has_tag else (model.split(":")[0] in present_base)
            if not already:
                print(f"[INSTALL] Pulling Ollama model: {model} …")
                try:
                    # Use subprocess so we can suppress the window entirely
                    subprocess.Popen(
                        ["ollama", "pull", model],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        creationflags=_CF,      # ← NO console window
                    ).wait(timeout=300)
                    print(f"[INSTALL] {model} ready.")
                except FileNotFoundError:
                    print("[INSTALL] ollama CLI not found — pull skipped.")
                    break
                except Exception as exc:
                    print(f"[INSTALL] WARNING: could not pull {model}: {exc}")
    except ImportError:
        print("[INSTALL] ollama package missing — model pull skipped.")
    except Exception as exc:
        # Catch-all: never let Ollama errors crash the installer
        print(f"[INSTALL] Ollama init error (non-fatal): {exc}")

    print("[ISHA] Self-install check complete.")



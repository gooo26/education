        self._launch_btn = QPushButton("🚀  Launch ISHA")
        self._launch_btn.setFixedHeight(38)
        self._launch_btn.setStyleSheet("""
            QPushButton { background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
                stop:0 #006880,stop:1 #003848);
                color: #00F0FF; font-size: 11pt; font-weight: bold;
                border: 2px solid rgba(0,240,255,160); border-radius: 8px; }
            QPushButton:hover { background: rgba(0,100,130,240); color: white; border: 2px solid rgb(0,240,255); }
            QPushButton:pressed { background: rgba(0,130,170,240); border: 2px solid rgb(0,255,180); }
        """)
        self._launch_btn.hide()
        self._launch_btn.clicked.connect(self.accept)
        root.addWidget(self._launch_btn)

    def _build_queue(self):
        for pkg in self._missing_pkgs:
            self._queue.append((
                f"Installing {pkg}...",
                [sys.executable, "-m", "pip", "install", pkg,
                 "--quiet", "--disable-pip-version-check"],
            ))
        for model in self._missing_models:
            self._queue.append((
                f"Pulling Ollama model: {model}...",
                ["ollama", "pull", model],
            ))

    def _log_line(self, text: str, color: str = "#58C8A0"):
        escaped = html.escape(text.rstrip())
        if escaped:
            self._log.append(f'<span style="color:{color};">{escaped}</span>')
            sb = self._log.verticalScrollBar()
            QTimer.singleShot(10, lambda: sb.setValue(sb.maximum()))

    def _run_next(self):
        if not self._queue:
            self._finish(); return
        label, argv = self._queue.pop(0)
        self._status_lbl.setText(label)
        self._log_line(f"\n▶  {label}", "#00D0C0")
        self._proc = QProcess(self)
        self._proc.setProcessChannelMode(QProcess.MergedChannels)
        self._proc.readyReadStandardOutput.connect(self._on_output)
        self._proc.finished.connect(self._on_proc_finished)
        self._proc.start(argv[0], argv[1:])

    def _on_output(self):
        if self._proc is None: return
        raw = bytes(self._proc.readAllStandardOutput()).decode("utf-8", errors="replace")
        for line in raw.splitlines():
            line = line.strip()
            if not line: continue
            if "pulling" in line.lower() or "%" in line:
                self._log_line(line, "#00A8C8")
            elif "error" in line.lower() or "warn" in line.lower():
                self._log_line(line, "#FF6060")
            else:
                self._log_line(line)

    def _on_proc_finished(self, exit_code: int, _exit_status):
        self._done_count += 1
        self._pbar.setValue(self._done_count)
        if exit_code != 0:
            self._log_line(f"  ⚠  Exit code {exit_code} — continuing...", "#FF8040")
        else:
            self._log_line("  ✓  Done.", "#00FF88")
        self._proc = None
        self._run_next()

    def _finish(self):
        self._pbar.setValue(self._total)
        self._status_lbl.setText("✓  All components ready — launching ISHA...")
        self._log_line("\n✦  Installation complete. ISHA is ready!", "#00F0FF")
        self._launch_btn.show()
        QTimer.singleShot(1200, self._launch_btn.click)

    def start_install(self):
        if not self._queue:
            QTimer.singleShot(0, self.accept); return
        parts = []
        if self._missing_pkgs:
            parts.append(f"{len(self._missing_pkgs)} package(s)")
        if self._missing_models:
            parts.append(f"{len(self._missing_models)} Ollama model(s)")
        self._log_line("Installing: " + ", ".join(parts), "#00D8FF")
        self._run_next()

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()
    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)
    def mouseReleaseEvent(self, e):
        self._drag_pos = None

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 16, 16)
        bg = QLinearGradient(0, 0, W // 2, H)
        bg.setColorAt(0, QColor(4, 8, 20, 254)); bg.setColorAt(1, QColor(8, 14, 35, 254))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 130), 1.8)); p.setBrush(Qt.NoBrush); p.drawPath(path)
        pen = QPen(QColor(0, 200, 255, 100), 1.4); p.setPen(pen)
        for (x, y, dx, dy) in [
            (2,2,14,0),(2,2,0,14),(W-2,2,-14,0),(W-2,2,0,14),
            (2,H-2,14,0),(2,H-2,0,-14),(W-2,H-2,-14,0),(W-2,H-2,0,-14)
        ]:
            p.drawLine(x, y, x+dx, y+dy)


class VoiceWorker(QObject):
    command_received  = pyqtSignal(str)
    listening_changed = pyqtSignal(bool)
    error_occurred    = pyqtSignal(str)

    _AMBIENT_INTERVAL = 45.0
    _MAX_BACKOFF      = 8.0
    _MAX_ERRORS       = 12

    def __init__(self):
        super().__init__()
        self._listening = False
        self._running   = False
        self._mic_ok    = None

    def set_listening(self, on: bool):
        if on and self._mic_ok is False:
            self.error_occurred.emit(
                "No microphone detected. Please connect a microphone.")
            self.listening_changed.emit(False)
            return
        self._listening = on
        if not on:
            self.listening_changed.emit(False)

    def run_loop(self):
        try:
            import speech_recognition as sr
        except ImportError:
            self.error_occurred.emit(
                "SpeechRecognition not installed. Run: pip install SpeechRecognition")
            return
        r = sr.Recognizer()
        r.pause_threshold          = 0.65
        r.non_speaking_duration    = 0.4
        r.dynamic_energy_threshold = True
        r.energy_threshold         = 300
        self._running      = True
        mic                = None
        consecutive_errors = 0
        last_ambient_cal   = 0.0
        phrase_limit       = 10
        while self._running:
            # Keep this thread's event loop responsive so any queued
            # cross-thread signal/slot calls (mute/unmute, quit, etc.)
            # are delivered even while we're inside this loop.
            QCoreApplication.processEvents()
            if not self._listening:
                time.sleep(0.12)
                continue
            if mic is None:
                try:
                    mic = sr.Microphone()
                    with mic as src:
                        r.adjust_for_ambient_noise(src, duration=0.5)
                    self._mic_ok     = True
                    last_ambient_cal = time.monotonic()
                except Exception as exc:
                    self._mic_ok    = False
                    self._listening = False
                    mic             = None
                    self.error_occurred.emit(
                        f"Microphone error: {exc}. Connect a microphone.")
                    self.listening_changed.emit(False)
                    continue
            now = time.monotonic()
            if now - last_ambient_cal > self._AMBIENT_INTERVAL:
                try:
                    with mic as src:
                        r.adjust_for_ambient_noise(src, duration=0.5)
                    last_ambient_cal = time.monotonic()
                except Exception:
                    pass
            self.listening_changed.emit(True)
            try:
                with mic as src:
                    audio = r.listen(src, timeout=5, phrase_time_limit=phrase_limit)
                recognised: Optional[str] = None
                try:
                    recognised = r.recognize_google(audio, language="en-IN")
                except sr.UnknownValueError:
                    pass
                except sr.RequestError as req_exc:
                    print(f"[VOICE] Google API unavailable: {req_exc}")
                if not recognised:
                    try:
                        recognised = r.recognize_sphinx(audio)
                    except Exception:
                        pass
                if recognised:
                    recognised = recognised.strip()
                    if recognised:
                        self.command_received.emit(recognised)
                        phrase_limit       = max(6, phrase_limit - 0.5)
                        consecutive_errors = 0
            except sr.WaitTimeoutError:
                pass
            except Exception as exc:
                consecutive_errors += 1
                backoff = min(self._MAX_BACKOFF, 0.5 * (2 ** min(consecutive_errors, 5)))
                phrase_limit = min(15, phrase_limit + 1.0)
                time.sleep(backoff)
                if consecutive_errors >= self._MAX_ERRORS:
                    self.error_occurred.emit(
                        "Voice recognition has persistent issues. Resetting microphone.")
                    consecutive_errors = 0; mic = None

    def quit(self):
        self._running   = False
        self._listening = False



class ResourceMonitorWorker(QThread):
    """
    Background worker class running on a separate QThread that checks
    system vitals every 10 seconds using psutil. Monitors CPU, RAM, and battery.
    If CPU/RAM crosses 85%, scans processes to find the heaviest resource user
    and emits warning_signal to flash an alert on CommDock and prompt user.
    """
    # Emits (proc_name, pid, warning_message)
    warning_signal = pyqtSignal(str, int, str)

    def __init__(self, parent=None):
        super().__init__(parent)
        self._running = True
        self.last_alert_time = 0.0

    def run(self):
        import psutil
        # Wait a few seconds for startup stability
        time.sleep(5)
        while self._running:
            try:
                cpu = psutil.cpu_percent(interval=None)
                ram = psutil.virtual_memory().percent
                
                if cpu > 85.0 or ram > 85.0:
                    current_time = time.time()
                    if current_time - self.last_alert_time >= 180.0:
                        heaviest_proc = None
                        heaviest_val = 0.0
                        heaviest_pid = 0
                        
                        for proc in psutil.process_iter(['pid', 'name', 'memory_percent', 'cpu_percent']):
                            try:
                                p_info = proc.info
                                pid = p_info.get('pid')
                                name = p_info.get('name') or ""
                                # Filter out system processes and empty states
                                if pid in (0, 4) or name.lower() in ("system idle process", "idle", "registry"):
                                    continue
                                    
                                cpu_load = p_info.get('cpu_percent') or 0.0
                                mem_load = p_info.get('memory_percent') or 0.0
                                total_load = cpu_load + mem_load
                                if total_load > heaviest_val:
                                    heaviest_val = total_load
                                    heaviest_proc = name
                                    heaviest_pid = pid
                            except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
                                continue
                                
                        if heaviest_proc:
                            msg = (
                                f"⚠️ [SYSTEM MONITOR ALERT] Boss, resource constraint detected! "
                                f"{heaviest_proc} background me heavy load de raha hai (CPU/RAM > 85%). "
                                f"Kya main isko kill kar ke PC optimize karoon?"
                            )
                            self.last_alert_time = current_time
                            self.warning_signal.emit(heaviest_proc, heaviest_pid, msg)
            except Exception as e:
                print(f"[ResourceMonitor] Error: {e}")
            
            # Check every 10 seconds safely
            for _ in range(100):
                if not self._running:
                    break
                time.sleep(0.1)

    def stop(self):
        self._running = False


def _execute_powershell_zip_unzip(text: str) -> str:
    """
    Parses and executes a zip/unzip command by shaping a native Windows PowerShell
    command chain and executing it cleanly via background pipes.
    """
    import subprocess
    tl = text.lower().strip()
    
    if "unzip" in tl:
        target = text
        for word in ["unzip", "this", "file", "archive", "please", "karo"]:
            target = re.sub(r'\b' + re.escape(word) + r'\b', '', target, flags=re.IGNORECASE)
        target_path = target.strip().strip("'\"")
        
        if not target_path:
            return "Boss, please specify the path of the zip file to unzip."
            
        if not os.path.exists(target_path):
            workspace_dir = os.path.join(os.path.expanduser("~"), "Desktop", "ISHA_Workspace")
            test_path = os.path.join(workspace_dir, target_path)
            if os.path.exists(test_path):
                target_path = test_path
            else:
                return f"Boss, I couldn't find the file at '{target_path}'."
                
        dest_dir = os.path.splitext(target_path)[0]
        ps_command = f'Expand-Archive -Path "{target_path}" -DestinationPath "{dest_dir}" -Force'
        
        try:
            _CF = subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0
            proc = subprocess.Popen(
                ["powershell", "-Command", ps_command],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                creationflags=_CF
            )
            stdout, stderr = proc.communicate(timeout=30)
            if proc.returncode == 0:
                _comm_log(f"[POWERSHELL SUCCESS] Unzipped {target_path} to {dest_dir}")
                return f"Done Boss! Unzipped successfully to '{dest_dir}'."
            else:
                _comm_log(f"[POWERSHELL ERROR] {stderr}")
                return f"Sorry Boss, PowerShell encountered an error: {stderr.strip()}"
        except Exception as exc:
            return f"Error executing unzip: {exc}"
            
    elif "zip" in tl:
        target = text
        for word in ["zip", "this", "folder", "directory", "file", "please", "karo"]:
            target = re.sub(r'\b' + re.escape(word) + r'\b', '', target, flags=re.IGNORECASE)
        target_path = target.strip().strip("'\"")
        
        if not target_path:
            return "Boss, please specify the folder or file path to zip."
            
        if not os.path.exists(target_path):
            workspace_dir = os.path.join(os.path.expanduser("~"), "Desktop", "ISHA_Workspace")
            test_path = os.path.join(workspace_dir, target_path)
            if os.path.exists(test_path):
                target_path = test_path
            else:
                return f"Boss, I couldn't find the folder or file at '{target_path}'."
                
        dest_zip = target_path.rstrip("/\\") + ".zip"
        ps_command = f'Compress-Archive -Path "{target_path}" -DestinationPath "{dest_zip}" -Force'
        
        try:
            _CF = subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0
            proc = subprocess.Popen(
                ["powershell", "-Command", ps_command],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                creationflags=_CF
            )
            stdout, stderr = proc.communicate(timeout=30)
            if proc.returncode == 0:
                _comm_log(f"[POWERSHELL SUCCESS] Zipped {target_path} to {dest_zip}")
                return f"Done Boss! Zipped successfully into '{dest_zip}'."
            else:
                _comm_log(f"[POWERSHELL ERROR] {stderr}")
                return f"Sorry Boss, PowerShell encountered an error: {stderr.strip()}"
        except Exception as exc:
            return f"Error executing zip: {exc}"
            
    return "Unknown archive command."


def _clean_temp_cache() -> str:
    """
    Loops through Windows temporary directories (%TEMP% and C:\\Windows\\Temp)
    and deletes accessible junk files while safely bypassing locked/system files.
    """
    import shutil
    cleaned_bytes = 0
    cleaned_files = 0
    failed_files = 0
    
    temp_dirs = []
    user_temp = os.environ.get("TEMP")
    if user_temp and os.path.isdir(user_temp):
        temp_dirs.append(user_temp)
    sys_temp = r"C:\Windows\Temp"
    if os.path.isdir(sys_temp):
        temp_dirs.append(sys_temp)
        
    for tdir in temp_dirs:
        _comm_log(f"[MAINTENANCE] Scanning cache directory: {tdir}")
        try:
            for item in os.listdir(tdir):
                item_path = os.path.join(tdir, item)
                try:
                    if os.path.isfile(item_path) or os.path.islink(item_path):
                        size = os.path.getsize(item_path)
                        os.unlink(item_path)
                        cleaned_bytes += size
                        cleaned_files += 1
                    elif os.path.isdir(item_path):
                        dir_size = 0
                        for root, dirs, files in os.walk(item_path):
                            for f in files:
                                fp = os.path.join(root, f)
                                if os.path.exists(fp):
                                    dir_size += os.path.getsize(fp)
                        shutil.rmtree(item_path)
                        cleaned_bytes += dir_size
                        cleaned_files += 1
                except Exception:
                    failed_files += 1
                    continue
        except Exception as e:
            _comm_log(f"[MAINTENANCE WARNING] Could not list/access '{tdir}': {e}")
            
    mb_cleaned = round(cleaned_bytes / (1024 * 1024), 2)
    res = f"Purged {cleaned_files} temp files/folders (~{mb_cleaned} MB freed). Bypassed {failed_files} locked files."
    _comm_log(f"[MAINTENANCE] {res}")
    return f"Done Boss! {res}"


def _refresh_explorer_system() -> str:
    """
    Triggers a deep explorer shell update using native win32 integration interfaces
    (or a clean shell fallback) to instantly flush desktop icon caches and refresh screen layouts,
    replicating a system-wide F5 trigger.
    """
    try:
        if os.name == "nt":
            import ctypes
            # Force explorer icon cache rebuild and association update
            ctypes.windll.shell32.SHChangeNotify(0x08000000, 0x0000, None, None)
            
            # Broadcast settings change message (F5 refresh equivalent)
            HWND_BROADCAST = 0xFFFF
            WM_SETTINGCHANGE = 0x001A
            ctypes.windll.user32.SendMessageW(HWND_BROADCAST, WM_SETTINGCHANGE, 0, 0)
            
            msg = "Desktop icon cache flushed and screen layouts refreshed successfully, Boss!"
        else:
            msg = "System refresh is supported on Windows environments only, Boss."
    except Exception as exc:
        try:
            import pyautogui
            pyautogui.press("f5")
            msg = "Triggered F5 refresh fallback, Boss!"
        except Exception as e:
            msg = f"System refresh failed: {exc} (Fallback: {e})"
            
    _comm_log(f"[MAINTENANCE] {msg}")
    return msg



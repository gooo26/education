                        headers={"Authorization": f"Bearer {api_key}",
                                 "Content-Type": "application/json"},
                        json={"model": "deepseek-chat", "messages": msgs, "max_tokens": 512},
                        timeout=20)
                    r.raise_for_status()
                    reply = r.json()["choices"][0]["message"]["content"].strip()
                    _comm_log(f"[CLOUD DeepSeek] {reply[:80]}")
                    return reply
                except Exception as exc:
                    _comm_log(f"[CLOUD API] DeepSeek error: {exc}")
                    continue

            # ── FALLBACK for unsupported vendors ────────────────────────────
            return (f"Cloud routing via {vendor} is active but a full SDK "
                    f"integration is required. Your key is saved.")

    except Exception as exc:
        _comm_log(f"[CLOUD API] Unexpected error: {exc}")
        print(f"[CLOUD API] Unexpected error: {exc}")

    return None






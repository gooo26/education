#  §10  GESTURE RECOGNIZER WORKER — Non-blocking QThread, full gesture suite
#       Swipe L/R → Arrow keys / Tab switching
#       Zoom In/Out (pinch distance) → OS display zoom  
#       Fist Clench → Close active window / minimize
#       Pinch (tap) → Left click
#       2-finger scroll → OS scroll
#       Right pinch (thumb+middle) → Right click
# ══════════════════════════════════════════════════════════════════════════════

# Keep the old class name as alias so existing ISHAWindow code doesn't break
GestureEngine = None  # Will be set after class definition


class GestureRecognizerWorker(QThread):
    """
    Non-blocking QThread for MediaPipe hand gesture recognition.
    All OS event simulation (pyautogui) happens via Qt signals on the GUI thread
    — this worker never calls pyautogui directly, ensuring zero GUI freezes.

    Signals emitted:
        gesture_detected(str)   — named gesture or "swipe_left", "swipe_right",
                                   "zoom_in", "zoom_out", "fist", "scroll:N",
                                   "left_click", "right_click", "volume_up/down"
        mouse_moved(int, int)   — absolute screen coords for cursor tracking
        mouse_clicked()         — simple left-click trigger
        gesture_status(str)     — human-readable status for GUI label
    """

    gesture_detected = pyqtSignal(str)
    mouse_moved      = pyqtSignal(int, int)
    mouse_clicked    = pyqtSignal()
    gesture_status   = pyqtSignal(str)   # ← NEW: feeds GUI status label

    # ── Geometry thresholds (normalised 0-1 coords) ─────────────────────────
    _PINCH_THRESH    = 0.055   # thumb-index distance for pinch/click
    _SWIPE_THRESH    = 0.12    # horizontal delta to register a swipe
    _ZOOM_THRESH     = 0.035   # change in pinch distance to trigger zoom
    _FIST_MARGIN     = 0.025   # finger-tip vs MCP delta for fist detection
    _SCROLL_THRESH   = 0.058   # index-middle gap for two-finger scroll mode
    _SCROLL_DELTA    = 0.018   # minimum vertical movement to scroll
    _VOL_MOVE_MIN    = 0.025
    _VOL_DELTA_MIN   = 0.012

    # ── Timing ───────────────────────────────────────────────────────────────
    _FPS_CAP         = 0.033   # ~30 fps when hand tracked
    _FPS_IDLE        = 0.050   # ~20 fps when no hand detected

    # ── Processing resolution (saves CPU vs full 1080p) ─────────────────────
    _PROC_W          = 480
    _PROC_H          = 270

    def __init__(self):
        super().__init__()
        self.setObjectName("ISHA-GestureWorker")
        self.setTerminationEnabled(True)
        self._active    = False
        self._running   = False
        self._screen_w  = 1920
        self._screen_h  = 1080
        self._prev_cx   = None
        self._prev_cy   = None

    # ── Public control API ───────────────────────────────────────────────────

    def set_screen_size(self, w: int, h: int):
        self._screen_w = max(1, int(w))
        self._screen_h = max(1, int(h))

    def set_active(self, on: bool):
        self._active = on
        if not on:
            self.gesture_status.emit("Status: Idle")

    def stop_engine(self):
        self._running = False
        self._active  = False

    # ── Geometry helpers ─────────────────────────────────────────────────────

    @staticmethod
    def _dist(lm, a: int, b: int) -> float:
        dx = lm[a].x - lm[b].x
        dy = lm[a].y - lm[b].y
        return (dx * dx + dy * dy) ** 0.5

    @staticmethod
    def _cooldown_ok(cd: dict, key: str, gap: float) -> bool:
        now = time.monotonic()
        if now - cd.get(key, 0.0) >= gap:
            cd[key] = now
            return True
        return False

    # ── Main recognition loop ────────────────────────────────────────────────

    def run(self):
        try:
            import cv2
            import mediapipe as mp
        except ImportError as exc:
            print("[TIP] Boss, run 'pip install mediapipe opencv-python' in your terminal to unlock Air Mouse Gestures!")
            self.gesture_detected.emit(
                f"__error__:Gesture engine unavailable — {exc}.")
            return

        mp_hands = mp.solutions.hands

        # Landmark indices
        THUMB  = 4;  INDEX  = 8;  MIDDLE = 12; RING = 16; PINKY = 20
        I_MCP  = 5;  M_MCP  = 9;  R_MCP  = 13; P_MCP = 17

        _d   = self._dist
        _cok = self._cooldown_ok

        self._running = True

        cap: Any                          = None
        cd:  Dict[str, float]             = {}

        # ── Per-gesture state ────────────────────────────────────────────────
        # Swipe tracking
        swipe_start_x:   Optional[float] = None
        prev_palm_x:     Optional[float] = None

        # Pinch / click tracking
        pinch_frames:    int              = 0
        vol_fired:       bool             = False
        pinch_start_x:   Optional[float] = None
        prev_pinch_x:    Optional[float] = None
        was_pinched:     bool             = False

        # Zoom tracking (pinch-spread between thumb & index)
        zoom_base_dist:  Optional[float] = None
        zoom_active:     bool            = False

        # Scroll tracking
        prev_scroll_y:   Optional[float] = None

        # Frame-skip counter
        fskip = 0

        with mp_hands.Hands(
            model_complexity=0,
            min_detection_confidence=0.70,
            min_tracking_confidence=0.60,
            max_num_hands=1,
            static_image_mode=False,
        ) as hands:

            while self._running:

                # ── Pause when deactivated ────────────────────────────────
                if not self._active:
                    if cap is not None:
                        cap.release(); cap = None
                    # Reset all state
                    swipe_start_x = prev_palm_x = None
                    pinch_frames  = 0; vol_fired = False
                    pinch_start_x = prev_pinch_x = None
                    zoom_base_dist = None; zoom_active = False
                    prev_scroll_y  = None
                    time.sleep(0.15)
                    continue

                # ── Open webcam ──────────────────────────────────────────
                if cap is None or not cap.isOpened():
                    cap = cv2.VideoCapture(0)
                    if not cap.isOpened():
                        self.gesture_detected.emit(
                            "__error__:Webcam unavailable.")
                        self.gesture_status.emit("Status: Webcam error")
                        self._active = False; cap = None
                        continue
                    cap.set(cv2.CAP_PROP_FRAME_WIDTH,  640)
                    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

                ret, frame = cap.read()
                if not ret:
                    time.sleep(self._FPS_IDLE)
                    continue

                # ── Frame-skip: process every 2nd frame ─────────────────
                fskip = (fskip + 1) % 2
                if fskip != 0:
                    time.sleep(self._FPS_CAP)
                    continue

                # ── Resize + MediaPipe inference ─────────────────────────
                small = cv2.resize(frame, (self._PROC_W, self._PROC_H),
                                   interpolation=cv2.INTER_LINEAR)
                rgb = cv2.cvtColor(small, cv2.COLOR_BGR2RGB)
                rgb.flags.writeable = False
                results = hands.process(rgb)

                # ── No hand detected ─────────────────────────────────────
                if not results.multi_hand_landmarks:
                    # Pending pinch release → left click
                    if pinch_frames > 0 and not vol_fired:
                        if _cok(cd, "left_click", 0.55):
                            self.gesture_status.emit("Status: Click Detected")
                            self.gesture_detected.emit("left_click")
                            self.mouse_clicked.emit()
                    # Reset all transient state
                    pinch_frames   = 0; vol_fired = False
                    pinch_start_x  = prev_pinch_x = None
                    swipe_start_x  = prev_palm_x  = None
                    zoom_base_dist = None; zoom_active = False
                    prev_scroll_y  = None
                    was_pinched    = False
                    self._prev_cx  = None
                    self._prev_cy  = None
                    time.sleep(self._FPS_IDLE)
                    continue

                lm = results.multi_hand_landmarks[0].landmark

                # ── 1. CURSOR TRACKING — index fingertip → screen coords ──
                # Use mirror-inversion (1.0 - x) so moving hand to right moves cursor to right
                raw_cx = int(min(max(1.0 - lm[INDEX].x, 0.0), 1.0) * self._screen_w)
                raw_cy = int(min(max(lm[INDEX].y, 0.0), 1.0) * self._screen_h)

                if self._prev_cx is None or self._prev_cy is None:
                    self._prev_cx = raw_cx
                    self._prev_cy = raw_cy
                else:
                    self._prev_cx = self._prev_cx + (raw_cx - self._prev_cx) * 0.20
                    self._prev_cy = self._prev_cy + (raw_cy - self._prev_cy) * 0.20

                cx = int(self._prev_cx)
                cy = int(self._prev_cy)
                self.mouse_moved.emit(cx, cy)

                # ── Precompute key distances ─────────────────────────────
                d_ti  = _d(lm, THUMB, INDEX)    # thumb–index (pinch)
                d_tm  = _d(lm, THUMB, MIDDLE)   # thumb–middle (right-click)
                d_im  = _d(lm, INDEX, MIDDLE)   # index–middle gap (scroll)

                # ── 2. FIST CLENCH → Close active window ─────────────────
                # All four finger tips below their respective MCPs
                fist = (
                    lm[INDEX].y  > lm[I_MCP].y  + self._FIST_MARGIN and
                    lm[MIDDLE].y > lm[M_MCP].y  + self._FIST_MARGIN and
                    lm[RING].y   > lm[R_MCP].y  + self._FIST_MARGIN and
                    lm[PINKY].y  > lm[P_MCP].y  + self._FIST_MARGIN
                )
                if fist and _cok(cd, "fist", 2.5):
                    self.gesture_status.emit("Status: Fist — Closing Window")
                    self.gesture_detected.emit("fist")
                    # Reset swipe/zoom so they don't interfere
                    swipe_start_x = prev_palm_x = None
                    zoom_base_dist = None
                    time.sleep(self._FPS_CAP)
                    continue

                # ── 3. SWIPE LEFT / RIGHT — palm horizontal sweep ────────
                # Use wrist (lm[0]) x-position as the palm anchor
                palm_x = lm[0].x
                if swipe_start_x is None:
                    swipe_start_x = palm_x
                    prev_palm_x   = palm_x
                else:
                    total_dx = palm_x - swipe_start_x
                    if abs(total_dx) >= self._SWIPE_THRESH and _cok(cd, "swipe", 0.6):
                        if total_dx > 0:
                            self.gesture_status.emit("Status: Swipe Right Detected")
                            self.gesture_detected.emit("swipe_right")
                        else:
                            self.gesture_status.emit("Status: Swipe Left Detected")
                            self.gesture_detected.emit("swipe_left")
                        swipe_start_x = palm_x  # reset baseline after swipe fires
                    prev_palm_x = palm_x

                # ── 4. ZOOM IN / OUT — thumb-index spread distance ────────
                # Only activate zoom when both index and middle are raised
                # (open hand) so it doesn't conflict with scroll
                index_up  = lm[INDEX].y  < lm[I_MCP].y - 0.04
                middle_up = lm[MIDDLE].y < lm[M_MCP].y - 0.04
                ring_down = lm[RING].y   > lm[R_MCP].y
                # Open-hand zoom: all main fingers up, not a pinch
                open_hand_zoom = index_up and middle_up and ring_down and d_ti > 0.07

                if open_hand_zoom:
                    if zoom_base_dist is None:
                        zoom_base_dist = d_ti
                    else:
                        delta_zoom = d_ti - zoom_base_dist
                        if abs(delta_zoom) >= self._ZOOM_THRESH and _cok(cd, "zoom", 0.30):
                            if delta_zoom > 0:
                                self.gesture_status.emit("Status: Zoom In")
                                self.gesture_detected.emit("zoom_in")
                            else:
                                self.gesture_status.emit("Status: Zoom Out")
                                self.gesture_detected.emit("zoom_out")
                            zoom_base_dist = d_ti  # update baseline
                else:
                    zoom_base_dist = None

                # ── 5. PINCH LEFT-CLICK (thumb+index close) ──────────────
                pinch_now = d_ti < self._PINCH_THRESH
                if pinch_now:
                    if not was_pinched:
                        if _cok(cd, "left_click", 0.45):
                            self.gesture_status.emit("Status: Click Detected")
                            self.gesture_detected.emit("left_click")
                            self.mouse_clicked.emit()
                        was_pinched = True
                    pinch_frames += 1
                    cur_x = lm[INDEX].x
                    if pinch_start_x is None:
                        pinch_start_x = cur_x
                    total_px = cur_x - pinch_start_x
                    if abs(total_px) > self._VOL_MOVE_MIN:
                        if prev_pinch_x is not None:
                            dp = cur_x - prev_pinch_x
                            if abs(dp) > self._VOL_DELTA_MIN and _cok(cd, "volume", 0.22):
                                g = "volume_up" if dp > 0 else "volume_down"
                                self.gesture_status.emit(
                                    f"Status: {'Vol Up' if dp > 0 else 'Vol Down'}")
                                self.gesture_detected.emit(g)
                        vol_fired = True
                    prev_pinch_x = cur_x
                else:
                    was_pinched = False
                    pinch_frames  = 0; vol_fired = False
                    pinch_start_x = prev_pinch_x = None

                # ── 6. RIGHT CLICK — thumb+middle pinch ──────────────────
                if d_tm < self._PINCH_THRESH and d_ti > self._PINCH_THRESH:
                    if _cok(cd, "right_click", 0.70):
                        self.gesture_status.emit("Status: Right Click")
                        self.gesture_detected.emit("right_click")

                # ── 7. TWO-FINGER SCROLL — index+middle together ─────────
                if index_up and middle_up and d_im < self._SCROLL_THRESH:
                    cur_y = lm[INDEX].y
                    if prev_scroll_y is not None:
                        dy = cur_y - prev_scroll_y
                        if abs(dy) > self._SCROLL_DELTA and _cok(cd, "scroll", 0.14):
                            clicks = -4 if dy < 0 else 4
                            direction = "Up" if dy < 0 else "Down"
                            self.gesture_status.emit(f"Status: Scroll {direction}")
                            self.gesture_detected.emit(f"scroll:{clicks}")
                    prev_scroll_y = cur_y
                else:
                    prev_scroll_y = None

                time.sleep(self._FPS_CAP)

        if cap is not None:
            cap.release()



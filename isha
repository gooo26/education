        self._entries_widget.setStyleSheet("background: transparent;")
        self._entries_lay = QVBoxLayout(self._entries_widget)
        self._entries_lay.setContentsMargins(0, 0, 0, 0)
        self._entries_lay.setSpacing(8)
        self._entries_lay.addStretch()
        self._scroll_area.setWidget(self._entries_widget)
        self._root_lay.addWidget(self._scroll_area)

        # FAB (+) button
        fab_row = QHBoxLayout()
        fab_row.addStretch()
        self._fab_btn = QPushButton("+")
        self._fab_btn.setFixedSize(46, 46)
        self._fab_btn.setStyleSheet("""
            QPushButton {
                background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
                    stop:0 #006080, stop:1 #003040);
                color: #00F0FF; font-size: 20pt; font-weight: bold;
                border: 2px solid rgba(0,240,255,140);
                border-radius: 23px;
            }
            QPushButton:hover {
                background: qlineargradient(x1:0,y1:0,x2:1,y2:1,
                    stop:0 #008090, stop:1 #004050);
                border: 2px solid rgb(0,240,255);
                color: #FFFFFF;
            }
            QPushButton:pressed {
                background: rgba(0,120,150,240);
                border: 2px solid rgb(0,255,180);
            }
        """)
        self._fab_btn.setCursor(Qt.PointingHandCursor)
        self._fab_btn.clicked.connect(self._on_fab)
        fab_row.addWidget(self._fab_btn)
        self._root_lay.addLayout(fab_row)

        close_btn = QPushButton("Close")
        close_btn.clicked.connect(self.close)
        self._root_lay.addWidget(close_btn, 0, Qt.AlignCenter)

        self._refresh_entries()

    def _refresh_entries(self):
        # Clear existing entry widgets (except stretch)
        while self._entries_lay.count() > 1:
            item = self._entries_lay.takeAt(0)
            if item and item.widget():
                item.widget().deleteLater()

        if not _API_MODE_CONFIGS:
            placeholder = QLabel(
                "<span style='color:#304560; font-size:9pt;'>"
                "No API configurations saved yet.<br>"
                "Click '+' to add one.</span>")
            placeholder.setAlignment(Qt.AlignCenter)
            placeholder.setWordWrap(True)
            self._entries_lay.insertWidget(0, placeholder)
            return

        for idx, cfg in enumerate(_API_MODE_CONFIGS):
            card = self._make_entry_card(idx, cfg)
            self._entries_lay.insertWidget(idx, card)

    def _make_entry_card(self, idx: int, cfg: dict) -> QWidget:
        card = QFrame()
        card.setStyleSheet("""
            QFrame {
                background: rgba(0,30,50,200);
                border: 1px solid rgba(0,200,255,80);
                border-radius: 10px;
            }
        """)
        card_lay = QHBoxLayout(card)
        card_lay.setContentsMargins(10, 8, 10, 8)
        card_lay.setSpacing(8)

        info_lay = QVBoxLayout()
        vendor_lbl = QLabel(f"<b style='color:#00D0F0;'>{cfg['vendor']}</b>")
        ts_lbl     = QLabel(f"<span style='color:#304560; font-size:7pt;'>"
                             f"Added: {cfg.get('ts','')}</span>")
        key_preview = cfg.get("key", "")
        key_preview = ("****" + key_preview[-4:]) if len(key_preview) > 4 else "****"
        key_lbl    = QLabel(f"<span style='color:#406080; font-size:8pt;'>Key: {key_preview}</span>")
        info_lay.addWidget(vendor_lbl)
        info_lay.addWidget(ts_lbl)
        info_lay.addWidget(key_lbl)
        card_lay.addLayout(info_lay, 1)

        # ON/OFF toggle
        toggle_btn = QPushButton("ON" if cfg.get("active") else "OFF")
        toggle_btn.setFixedSize(52, 28)
        active = cfg.get("active", False)
        toggle_btn.setStyleSheet(
            f"QPushButton {{ background: {'rgba(0,160,80,200)' if active else 'rgba(60,20,20,200)'}; "
            f"color: {'#00FF80' if active else '#FF4040'}; "
            f"border: 1px solid {'rgba(0,255,100,100)' if active else 'rgba(255,60,60,100)'}; "
            f"border-radius: 6px; font-weight: bold; font-size: 9pt; }}"
        )
        toggle_btn.setCursor(Qt.PointingHandCursor)
        toggle_btn.clicked.connect(lambda _, i=idx: self._toggle_active(i))
        card_lay.addWidget(toggle_btn)

        # Edit button
        edit_btn = QPushButton("Edit")
        edit_btn.setFixedSize(44, 28)
        edit_btn.setCursor(Qt.PointingHandCursor)
        edit_btn.clicked.connect(lambda _, i=idx: self._on_edit(i))
        card_lay.addWidget(edit_btn)

        # Delete button
        del_btn = QPushButton("✕")
        del_btn.setFixedSize(28, 28)
        del_btn.setStyleSheet("""
            QPushButton { background: rgba(80,0,0,200); color: #FF4040;
                border: 1px solid rgba(255,60,60,80); border-radius: 6px; }
            QPushButton:hover { background: rgba(120,0,0,220); border: 1px solid rgb(255,80,80); color: #FFFFFF; }
            QPushButton:pressed { background: rgba(180,0,0,240); }
        """)
        del_btn.setCursor(Qt.PointingHandCursor)
        del_btn.clicked.connect(lambda _, i=idx: self._on_delete(i))
        card_lay.addWidget(del_btn)

        return card

    def _on_fab(self):
        if len(_API_MODE_CONFIGS) >= 3:
            CyberpunkDialog.info(self, "Limit Reached",
                "Maximum of 3 API configurations allowed.\n"
                "Remove an existing one before adding a new one.")
            return
        dlg = _ApiAddDialog(self)
        if dlg.exec_() == QDialog.Accepted:
            new_cfg = {
                "vendor": dlg.accepted_vendor,
                "key":    dlg.accepted_key,
                "ts":     datetime.now().strftime("%Y-%m-%d %H:%M"),
                "active": False,
            }
            with _API_MODE_LOCK:
                _API_MODE_CONFIGS.append(new_cfg)
                _save_api_mode_configs()
            self._refresh_entries()

    def _on_edit(self, idx: int):
        dlg = _ApiAddDialog(self, edit_index=idx)
        if dlg.exec_() == QDialog.Accepted:
            with _API_MODE_LOCK:
                _API_MODE_CONFIGS[idx]["vendor"] = dlg.accepted_vendor
                _API_MODE_CONFIGS[idx]["key"]    = dlg.accepted_key
                _save_api_mode_configs()
            self._refresh_entries()

    def _toggle_active(self, idx: int):
        with _API_MODE_LOCK:
            current = _API_MODE_CONFIGS[idx].get("active", False)
            if not current:
                # Check active count limit
                active_count = sum(1 for c in _API_MODE_CONFIGS if c.get("active"))
                if active_count >= 2:
                    CyberpunkDialog.info(self, "Limit Reached",
                        "Maximum of 2 APIs can be active simultaneously.\n"
                        "Turn off another API first.")
                    return
            _API_MODE_CONFIGS[idx]["active"] = not current
            _save_api_mode_configs()
        self._refresh_entries()

    def _on_delete(self, idx: int):
        vendor = _API_MODE_CONFIGS[idx]["vendor"]
        if CyberpunkDialog.confirm(self, "Remove API",
                                    f"Remove '{vendor}' configuration?"):
            with _API_MODE_LOCK:
                _API_MODE_CONFIGS.pop(idx)
                _save_api_mode_configs()
            self._refresh_entries()

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 14, 14)
        bg = QLinearGradient(0, 0, W // 2, H)
        bg.setColorAt(0, QColor(4, 8, 20, 254))
        bg.setColorAt(1, QColor(8, 14, 35, 254))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 100), 1.5))
        p.setBrush(Qt.NoBrush); p.drawPath(path)

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()

    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)

    def mouseReleaseEvent(self, e):
        self._drag_pos = None




def _handle_pending(text: str) -> str:
    global _PENDING_STATE
    step = _PENDING_STATE.get("step")
    if step == "api_name":
        if not text.strip():
            _PENDING_STATE = {}
            msg = "API management cancelled."; speak(msg); return msg
        _PENDING_STATE = {"step": "api_key", "name": text.strip()}
        msg = f"Got it. Now paste the API key for '{text.strip()}':"
        speak(msg); return msg
    elif step == "api_key":
        name = _PENDING_STATE.get("name", "unknown")
        _PENDING_STATE = {}
        return cmd_api_save(name, text.strip())
    elif step == "resource_kill":
        proc_name = _PENDING_STATE.get("proc_name")
        pid = _PENDING_STATE.get("pid")
        _PENDING_STATE = {}
        
        cleaned = text.strip().lower()
        if any(w in cleaned for w in ("yes", "kill", "optimize", "ha", "haan", "kar do", "maro")):
            import psutil
            try:
                p = psutil.Process(pid)
                p.terminate()
                p.wait(timeout=3)
                msg = f"Done Boss! Terminated process '{proc_name}' (PID: {pid}) successfully. PC optimized!"
            except Exception:
                try:
                    subprocess.run(["taskkill", "/F", "/PID", str(pid)], creationflags=subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0)
                    msg = f"Done Boss! Force killed '{proc_name}' (PID: {pid}) via taskkill. PC optimized!"
                except Exception as e:
                    msg = f"Could not kill process: {e}"
            speak(msg)
            _comm_log(msg)
            return msg
        else:
            msg = "Cancelled. Process termination skipped."
            speak(msg)
            _comm_log(msg)
            return msg
    _PENDING_STATE = {}
    msg = "I lost track of context. Please try again."
    speak(msg); return msg


def _handle_api_command(text: str) -> str:
    global _PENDING_STATE
    tl    = text.strip().lower()
    parts = text.strip().split(None, 2)
    if tl.startswith("apir"):
        api_name = " ".join(parts[1:]).strip() if len(parts) > 1 else ""
        if not api_name:
            msg = ("Which API key should I remove? "
                   "Type 'apir <service name>'. " + cmd_api_list())
            speak(msg); return msg
        return cmd_api_remove(api_name)
    if len(parts) >= 3 and parts[0].lower() == "apis":
        return cmd_api_save(parts[1], parts[2])
    if len(parts) == 2 and parts[0].lower() == "apis":
        _PENDING_STATE = {"step": "api_key", "name": parts[1]}
        msg = f"Please paste the API key for '{parts[1]}':"
        speak(msg); return msg
    existing = cmd_api_list()
    _PENDING_STATE = {"step": "api_name"}
    msg = (f"{existing} "
           "To add a key, enter the service name (e.g. 'openweather'):")
    speak(msg); return msg



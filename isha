class ISHAWindow(QMainWindow):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("ISHA")
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self.setFixedSize(760, 82)
        self._centre()

        self._drag_pos   = None
        self._mic_on     = False
        self._chat_vis   = False
        self._qs_popup   : Optional[QuickSettingsPopup] = None
        self._hist_win   : Optional[HistoryManagerWindow] = None
        self._comm_dock  : Optional[CommDockWindow] = None

        self._stars  = [Star(760, 82) for _ in range(72)]
        self._ptimer = QTimer(self)
        self._ptimer.timeout.connect(self._tick)
        self._ptimer.start(15)

        self._build_ui()

        # Voice thread
        self._vthread = QThread(self)
        self._vworker = VoiceWorker()
        self._vworker.moveToThread(self._vthread)
        self._vthread.started.connect(self._vworker.run_loop)
        self._vworker.command_received.connect(self._on_voice)
        self._vworker.listening_changed.connect(self._on_listen)
        self._vworker.error_occurred.connect(self._on_voice_err)
        self._vthread.start()

        # Command worker thread
        self._cthread = QThread(self)
        self._cworker = _CmdWorker()
        self._cworker.moveToThread(self._cthread)
        self._cworker.result.connect(self._on_result)
        self._cthread.start()

        # Gesture Engine
        global _GESTURE_ENGINE
        self._gesture_engine = GestureEngine()
        screen = QApplication.primaryScreen().size()
        self._gesture_engine.set_screen_size(screen.width(), screen.height())
        self._gesture_engine.gesture_detected.connect(
            self._on_gesture, Qt.QueuedConnection)
        self._gesture_engine.mouse_moved.connect(
            self._on_gesture_mouse_move, Qt.QueuedConnection)
        self._gesture_engine.mouse_clicked.connect(
            self._on_gesture_mouse_click, Qt.QueuedConnection)
        # Wire gesture status signal → GUI status label
        self._gesture_engine.gesture_status.connect(
            self._on_gesture_status, Qt.QueuedConnection)
        self._gesture_engine.start()
        _GESTURE_ENGINE = self._gesture_engine

        # Global Hotkey
        self._hotkey_thread = HotkeyListener()
        self._hotkey_thread.hotkey_pressed.connect(
            self._on_hotkey, Qt.QueuedConnection)
        self._hotkey_thread.start()

        # Resource telemetry monitor (Step 3)
        self._res_monitor = ResourceMonitorWorker(self)
        self._res_monitor.warning_signal.connect(self._on_resource_warning)
        self._res_monitor.start()

        # Wire async callback
        global _GUI_CB
        _GUI_CB = self._safe_respond

        # Fade-in
        self.setWindowOpacity(0.0)
        fa = QPropertyAnimation(self, b"windowOpacity")
        fa.setDuration(650); fa.setStartValue(0.0); fa.setEndValue(1.0)
        fa.setEasingCurve(QEasingCurve.OutCubic); fa.start()
        self._fa = fa

        QTimer.singleShot(900, self._greet)

    def _build_ui(self):
        root = QWidget(self)
        root.setAttribute(Qt.WA_TranslucentBackground)
        self.setCentralWidget(root)

        ml = QVBoxLayout(root)
        ml.setContentsMargins(0, 0, 0, 0); ml.setSpacing(0)

        upper = QWidget(root)
        upper.setAttribute(Qt.WA_TranslucentBackground)
        upper.setFixedHeight(0)
        ul = QVBoxLayout(upper)
        ul.setContentsMargins(16, 0, 16, 6); ul.setSpacing(6)
        ul.addStretch(); ml.addWidget(upper)

        bar = QWidget(root)
        bar.setAttribute(Qt.WA_TranslucentBackground); bar.setFixedHeight(82)
        bl = QHBoxLayout(bar)
        bl.setContentsMargins(18, 11, 18, 11); bl.setSpacing(10)

        self.mic_btn      = MicButton(bar)
        self.search_bar   = SearchBar(bar)
        self.wave_bar     = WaveformBar(bar)
        self.dots         = ThinkingDots(bar)
        self.settings_btn = SettingsButton(bar)

        self.mic_btn.clicked.connect(self._toggle_mic)
        self.search_bar.submitted.connect(self._on_typed)
        self.settings_btn.clicked.connect(self._toggle_qs)

        bl.addWidget(self.mic_btn); bl.addWidget(self.search_bar)
        bl.addWidget(self.wave_bar); bl.addWidget(self.dots)
        bl.addWidget(self.settings_btn)
        ml.addWidget(bar)

        self._bubble = BubbleLabel(self)
        self._chat   = ChatPanel(self); self._chat.hide()

        # Comm Dock button — only remaining icon button in title area
        self._cdockbtn = _CommDockBtn(self)
        self._cdockbtn.clicked.connect(self._toggle_comm_dock)
        self._cdockbtn.move(self.width() - 42, 6)

        # ── Gesture Status Label — small HUD indicator ────────────────────
        # Appears at bottom-left of the main bar; shows active gesture status
        self._gesture_lbl = QLabel("Gesture: Idle", self)
        self._gesture_lbl.setFont(QFont("Segoe UI", 7))
        self._gesture_lbl.setStyleSheet(
            "color: rgba(0,200,255,160); background: transparent; "
            "padding: 1px 4px;"
        )
        self._gesture_lbl.setFixedWidth(160)
        self._gesture_lbl.move(8, self.height() - 18)
        self._gesture_lbl.show()

        # Auto-reset gesture label after 2 seconds
        self._gesture_lbl_timer = QTimer(self)
        self._gesture_lbl_timer.setSingleShot(True)
        self._gesture_lbl_timer.timeout.connect(
            lambda: self._gesture_lbl.setText("Gesture: Idle"))

    def _on_gesture_status(self, status: str):
        """Slot: update the gesture status label in the GUI (GUI thread only)."""
        self._gesture_lbl.setText(status)
        self._gesture_lbl_timer.start(2000)   # auto-reset after 2 s

    def respond(self, text: str, role: str = "isha"):
        if not text:
            return
        if role == "isha":
            _TTS_BRIDGE.request_speak(text)
        self._place_bubble(text)
        self._bubble.show_text(text, role)
        self._chat.add_entry(text, role)
        if role == "isha":
            short = text[:46] + ("…" if len(text) > 46 else "")
            self.search_bar.setPlaceholderText(f"✦  {short}")
            QTimer.singleShot(5500, lambda:
                self.search_bar.setPlaceholderText("Ask ISHA anything…"))

    def _safe_respond(self, text: str):
        QTimer.singleShot(0, lambda: self.respond(text, "isha"))

    def _on_resource_warning(self, proc_name: str, pid: int, msg: str):
        # Prevent Telemetry warning from overwriting if speaking or thinking/typing or bubble visible
        is_speaking = _TTS.is_speaking()
        is_thinking = getattr(self, "dots", None) is not None and self.dots._on
        is_bubble_visible = getattr(self, "_bubble", None) is not None and self._bubble.isVisible()
        
        if is_speaking or is_thinking or is_bubble_visible:
            _comm_log(f"[Telemetry Alert Suppressed] {proc_name} (PID: {pid}) - AI is speaking, thinking, or displaying content.")
            return

        global _PENDING_STATE
        _PENDING_STATE = {
            "step": "resource_kill",
            "proc_name": proc_name,
            "pid": pid
        }
        _comm_log(msg)
        self._safe_respond(msg)

    def _place_bubble(self, text: str):
        fm   = QFontMetrics(QFont("Segoe UI", 11))
        mw   = min(520, self.width() - 40)
        rect = fm.boundingRect(QRectF(0, 0, mw, 9999).toRect(),
                                Qt.TextWordWrap, text)
        bw = rect.width() + 52; bh = rect.height() + 30
        bx = (self.width() - bw) // 2
        by = self.height() - 82 - bh - 8
        self._bubble.setParent(self)
        self._bubble.setFixedSize(bw, bh)
        self._bubble.move(bx, max(2, by))

    def _on_typed(self, text: str):
        self.respond(text, "user")
        self.search_bar.setPlaceholderText("⟳  Thinking…")
        content = getattr(self.search_bar, "dropped_file_content", None)
        if content and "[File:" in text:
            full_query = f"{text}\n\n=== DROPPED FILE CONTENT ===\n{content}\n============================"
            self.search_bar.dropped_file_content = None
        else:
            full_query = text
        self.dots.start(); self._cworker.enqueue(full_query)

    def _on_voice(self, text: str):
        self.respond(text, "user")
        self.dots.start(); self._cworker.enqueue(text)

    def _on_result(self, response: str):
        self.dots.stop(); self.respond(response, "isha")
        if self._hist_win and self._hist_win.isVisible():
            QTimer.singleShot(80, self._hist_win.refresh)

    def _on_listen(self, listening: bool):
        self.wave_bar.set_active(listening)

    def _on_voice_err(self, msg: str):
        self._mic_on = False
        self.mic_btn.set_active(False)
        self.wave_bar.set_active(False)
        self.respond(msg, "isha")

    def _on_gesture_mouse_move(self, x: int, y: int):
        """Thread-safe slot: runs on the GUI thread, moves the OS cursor."""
        try:
            import pyautogui
            pyautogui.moveTo(x, y, duration=0)
        except Exception as exc:
            _comm_log(f"[GESTURE] moveTo error: {exc}")

    def _on_gesture_mouse_click(self):
        """Thread-safe slot: runs on the GUI thread, performs a left click."""
        try:
            import pyautogui
            pyautogui.click()
        except Exception as exc:
            _comm_log(f"[GESTURE] click error: {exc}")

    def _on_gesture(self, gesture: str):
        """
        Thread-safe slot: runs on GUI thread via QueuedConnection.
        Handles all gesture events emitted by GestureRecognizerWorker.
        pyautogui is ONLY called here (GUI thread) — never in the worker thread.
        """
        try:
            import pyautogui
        except ImportError:
            self._safe_respond("pyautogui is not installed — gestures need it.")
            return

        if gesture.startswith("__error__:"):
            self._safe_respond(gesture[len("__error__:"):])
            if _GESTURE_ENGINE is not None:
                _GESTURE_ENGINE.set_active(False)
            return

        try:
            # ── Click gestures ────────────────────────────────────────────
            if gesture == "left_click":
                pass   # handled via mouse_clicked signal → _on_gesture_mouse_click

            elif gesture == "right_click":
                pyautogui.click(button="right")
                _comm_log("[GESTURE] Right click")

            # ── SWIPE LEFT → Left arrow key + switch tab ──────────────────
            elif gesture == "swipe_left":
                pyautogui.hotkey("alt", "left")   # browser Back / prev tab
                pyautogui.press("left")            # arrow key fallback
                _comm_log("[GESTURE] Swipe Left → Alt+Left + Arrow Left")

            # ── SWIPE RIGHT → Right arrow key + switch tab ────────────────
            elif gesture == "swipe_right":
                pyautogui.hotkey("alt", "right")   # browser Forward / next tab
                pyautogui.press("right")
                _comm_log("[GESTURE] Swipe Right → Alt+Right + Arrow Right")

            # ── ZOOM IN → Ctrl+= (OS/browser zoom in) ────────────────────
            elif gesture == "zoom_in":
                pyautogui.hotkey("ctrl", "=")
                _comm_log("[GESTURE] Zoom In → Ctrl+=")

            # ── ZOOM OUT → Ctrl+- (OS/browser zoom out) ──────────────────
            elif gesture == "zoom_out":
                pyautogui.hotkey("ctrl", "-")
                _comm_log("[GESTURE] Zoom Out → Ctrl+-")

            # ── FIST CLENCH → Close active window (Alt+F4) ───────────────
            elif gesture == "fist":
                pyautogui.hotkey("alt", "f4")
                _comm_log("[GESTURE] Fist → Alt+F4 (close window)")
                self._safe_respond("On it, Boss — closing active window.")

            # ── SCROLL ───────────────────────────────────────────────────
            elif gesture.startswith("scroll:"):
                try:
                    pyautogui.scroll(int(gesture.split(":", 1)[1]))
                except (ValueError, IndexError):
                    pass

            # ── VOLUME ───────────────────────────────────────────────────
            elif gesture == "volume_up":
                pyautogui.press("volumeup")

            elif gesture == "volume_down":
                pyautogui.press("volumedown")

            # ── Legacy screenshot gesture (kept for back-compat) ─────────
            elif gesture == "screenshot":
                result = cmd_screenshot()
                self._safe_respond(f"Gesture screenshot: {result}")

        except Exception as exc:
            _comm_log(f"[GESTURE] Action error for '{gesture}': {exc}")

    def _on_hotkey(self):
        if not self.isVisible(): self.show()
        if self.isMinimized(): self.showNormal()
        self.raise_(); self.activateWindow()
        self.search_bar.setFocus()
        self.search_bar.setPlaceholderText("Ask ISHA anything…")

    def _toggle_mic(self):
        self._mic_on = not self._mic_on
        self.mic_btn.set_active(self._mic_on)
        self._vworker.set_listening(self._mic_on)
        msg = ("Microphone activated. I'm listening…"

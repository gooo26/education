def main():
    # ── Physical Workspace initialization (Step 2) ────────────────────────
    wdir = os.path.join(os.path.expanduser("~"), "Desktop", "ISHA_Workspace")
    os.makedirs(wdir, exist_ok=True)

    # ── Qt must start before any QWidget ──────────────────────────────────
    QApplication.setAttribute(Qt.AA_EnableHighDpiScaling, True)
    QApplication.setAttribute(Qt.AA_UseHighDpiPixmaps,    True)
    app = QApplication(sys.argv)
    app.setApplicationName("ISHA")
    app.setQuitOnLastWindowClosed(False)

    # ── v11 Visual Installer: show GUI dialog for missing deps ────────────
    missing_pkgs   = _missing_packages()
    missing_models = _missing_models()

    if missing_pkgs or missing_models:
        installer = InstallerDialog(missing_pkgs, missing_models)
        installer.start_install()
        result = installer.exec_()
        # If user closes the installer before it finishes, still continue
        if result == QDialog.Rejected:
            # They closed manually — proceed anyway
            pass

    # ── Start TTS engine ──────────────────────────────────────────────────
    _TTS.start()

    # ── Animated post-install splash ──────────────────────────────────────
    splash = SplashScreen(); splash.show()
    app.processEvents()

    win  = ISHAWindow()
    tray = _setup_tray(app, win)

    splash.done.connect(win.show)
    app.aboutToQuit.connect(win.close)

    sys.exit(app.exec_())


if __name__ == "__main__":
    main()

    def _toggle_qs(self):
        if not self._qs_popup:
            self._qs_popup = QuickSettingsPopup(self)
        # Always keep the hist_win reference fresh (created lazily on demand)
        if self._hist_win is None:
            self._hist_win = HistoryManagerWindow()
        self._qs_popup._hist_win_ref = self._hist_win
        btn_g = self.mapToGlobal(self.settings_btn.pos())
        popup_w = self._qs_popup.sizeHint().width() or 290
        popup_h = self._qs_popup.sizeHint().height() or 420
        px = btn_g.x() - popup_w + 54
        py = btn_g.y() - popup_h - 12
        self._qs_popup.toggle(QPoint(px, py))

    def _toggle_chat(self):
        self._chat_vis = not self._chat_vis
        if self._chat_vis:
            pw, ph = self._chat.width(), self._chat.height()
            self._chat.move((self.width() - pw) // 2,
                             self.height() - 82 - ph - 10)
            self._chat.toggle()
            self.setFixedSize(760, 82 + min(ph + 12, 352))
        else:
            self._chat.toggle()
            QTimer.singleShot(320, lambda: self.setFixedSize(760, 82))
        self._centre()

    def _open_history_manager(self):
        if not self._hist_win:
            self._hist_win = HistoryManagerWindow()
        # Keep quick-settings grid in sync
        if self._qs_popup is not None:
            self._qs_popup._hist_win_ref = self._hist_win
        if self._hist_win.isVisible():
            self._hist_win.hide()
        else:
            self._hist_win.show(); self._hist_win.raise_()

    def _toggle_comm_dock(self):
        if not self._comm_dock:
            self._comm_dock = CommDockWindow()
            sc = QApplication.primaryScreen().geometry()
            self._comm_dock.move(
                sc.width()  - self._comm_dock.width()  - 20,
                sc.height() - self._comm_dock.height() - 80,
            )
        if self._comm_dock.isVisible():
            self._comm_dock.hide()
        else:
            self._comm_dock.show(); self._comm_dock.raise_()

    def _greet(self):
        from datetime import datetime
        h = datetime.now().hour
        
        if 5 <= h < 12:
            wish = "Good morning"
        elif 12 <= h < 17:
            wish = "Good afternoon"
        elif 17 <= h < 21:
            wish = "Good evening"
        else:
            wish = "Welcome back"

        #
        greeting_text = (
            f"{wish}, Boss! Biometric signature confirmed. "
            f"Dual Qwen Core is online at zero-latency. Mainframe secured. "
            f"Awaiting your command."
        )
        self.respond(greeting_text, "isha")

    def _tick(self):
        for s in self._stars: s.update()
        self.update()

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        cap = QPainterPath()
        cap.addRoundedRect(QRectF(0, H - 82, W, 82), 41, 41)
        p.setClipPath(cap)
        bg = QLinearGradient(0, H - 82, W, H)
        bg.setColorAt(0.0, QColor(  7, 10, 20, 254))
        bg.setColorAt(0.5, QColor( 18, 23, 38, 252))
        bg.setColorAt(1.0, QColor(  7, 10, 20, 254))
        p.fillPath(cap, QBrush(bg))
        stars = self._stars
        for i in range(len(stars)):
            for j in range(i + 1, min(i + 10, len(stars))):
                d = math.hypot(stars[i].x - stars[j].x, stars[i].y - stars[j].y)
                if d < 70:
                    a = int(50 * (1 - d / 70))
                    p.setPen(QPen(QColor(0, 180, 220, a), 0.5))
                    p.drawLine(QPointF(stars[i].x, H - 82 + stars[i].y),
                               QPointF(stars[j].x, H - 82 + stars[j].y))
        p.setPen(Qt.NoPen)
        for s in stars:
            p.setBrush(QBrush(s.color))
            p.drawEllipse(QPointF(s.x, H - 82 + s.y), s.sz, s.sz)
        p.setClipping(False)
        p.setPen(QPen(QColor(0, 240, 255, 200), 2.0))
        p.setBrush(Qt.NoBrush); p.drawPath(cap)
        sheen = QPainterPath()
        sheen.addRoundedRect(QRectF(3, H - 82 + 3, W - 6, 28), 38, 38)
        p.fillPath(sheen, QColor(255, 255, 255, 6))
        cx = W // 2
        lg = QLinearGradient(cx - 120, H - 82, cx + 120, H - 82)
        lg.setColorAt(0.0, QColor(0, 0, 0, 0))
        lg.setColorAt(0.5, QColor(0, 240, 255, 60))
        lg.setColorAt(1.0, QColor(0, 0, 0, 0))
        p.setPen(QPen(QBrush(lg), 1))
        p.drawLine(QPointF(cx - 120, H - 41), QPointF(cx + 120, H - 41))

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()

    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)

    def mouseReleaseEvent(self, e):
        self._drag_pos = None

    def _centre(self):
        sc = QApplication.primaryScreen().geometry()
        self.move(
            (sc.width()  - self.width())  // 2,
             sc.height() - self.height()  - 60,
        )

    def closeEvent(self, e):
        _TTS.shutdown()
        if hasattr(self, "_res_monitor") and self._res_monitor:
            self._res_monitor.stop(); self._res_monitor.wait(2000)
        if self._hist_win: self._hist_win.close()
        if self._comm_dock: self._comm_dock.close()
        self._vworker.quit()
        self._vthread.quit(); self._vthread.wait(2000)
        self._cthread.quit(); self._cthread.wait(2000)
        if hasattr(self, "_gesture_engine") and self._gesture_engine:
            self._gesture_engine.stop_engine(); self._gesture_engine.wait(2000)
        if hasattr(self, "_hotkey_thread") and self._hotkey_thread:
            self._hotkey_thread.stop_listener(); self._hotkey_thread.wait(2000)
        e.accept()



    def _do_display(self, on: bool):
        _popen_silent("start ms-settings:display")
        _comm_log(f"Display settings opened (toggle: {on})")
        # Display is a one-shot launch, reset toggle immediately
        QTimer.singleShot(400, lambda: self._t_display.set_on(False))

    def _do_hand_control(self, on: bool):
        global _GESTURE_ENGINE
        if _GESTURE_ENGINE is not None:
            if on and not _GESTURE_ENGINE.isRunning():
                _GESTURE_ENGINE.start()
            _GESTURE_ENGINE.set_active(on)
            _comm_log(f"Hand gesture engine: {'active' if on else 'inactive'}")
            status = "Hand gesture control activated! Show your hand to camera." if on else "Hand gesture control deactivated."
            speak(status)
        else:
            _comm_log("[QS] Gesture engine not initialised.")
            self._t_hand_control.set_on(False)

    def _do_model_settings(self, on: bool):
        """Open/close Local Models Controller popup."""
        if on:
            if not self._model_popup:
                self._model_popup = ModelSettingsPopup()
            sc   = QApplication.primaryScreen().geometry()
            mw   = self._model_popup.sizeHint().width()  or 360
            mh   = self._model_popup.sizeHint().height() or 420
            self._model_popup.move(
                (sc.width()  - mw) // 2,
                (sc.height() - mh) // 2,
            )
            self._model_popup.show(); self._model_popup.raise_()
            self._model_popup._load_models()
            _comm_log("Model Settings popup opened")
        else:
            if self._model_popup and self._model_popup.isVisible():
                self._model_popup.hide()
            self._t_model_settings.set_on(False)

    def _do_chat_history(self, on: bool):
        """Open/close the full Chat History Manager window."""
        # Lazy-create the history window if the ref was not yet injected
        if self._hist_win_ref is None:
            # Try to create one directly (works when called from QuickSettings
            # after ISHAWindow has initialised _hist_win)
            try:
                hw = HistoryManagerWindow()
                self._hist_win_ref = hw
            except Exception as exc:
                _comm_log(f"[QS] Could not create HistoryManagerWindow: {exc}")
                self._t_chat_history.set_on(False)
                return

        if on:
            self._hist_win_ref.show()
            self._hist_win_ref.raise_()
            self._hist_win_ref.activateWindow()
            _comm_log("Chat History opened from Quick Settings")
        else:
            self._hist_win_ref.hide()
            self._t_chat_history.set_on(False)

    def _set_vol(self, v: int):
        _comm_log(f"Volume slider: {v}%")
        _TTS.set_volume(v)
        # Throttle: apply on slider idle to avoid flooding OS
        if not hasattr(self, "_vol_apply_timer"):
            self._vol_apply_timer = QTimer(self)
            self._vol_apply_timer.setSingleShot(True)
            self._vol_apply_timer.timeout.connect(
                lambda: self._apply_system_volume(self._vol.value()))
        self._vol_apply_timer.start(80)

    def _on_vol_released(self):
        """Also apply immediately when the slider handle is released."""
        _TTS.set_volume(self._vol.value())
        self._apply_system_volume(self._vol.value())

    def _apply_system_volume(self, v: int):
        """Apply volume to the OS audio system (cross-platform)."""
        try:
            if sys.platform == "win32":
                try:
                    from ctypes import cast, POINTER
                    from comtypes import CLSCTX_ALL
                    from pycaw.pycaw import AudioUtilities, IAudioEndpointVolume
                    devices = AudioUtilities.GetSpeakers()
                    interface = devices.Activate(IAudioEndpointVolume._iid_, CLSCTX_ALL, None)
                    vol_ctrl = cast(interface, POINTER(IAudioEndpointVolume))
                    vol_ctrl.SetMasterVolumeLevelScalar(v / 100.0, None)
                    return
                except Exception:
                    pass
                # Fallback: nircmd if available
                subprocess.Popen(
                    ["nircmd", "setsysvolume", str(int(v / 100 * 65535))],
                    creationflags=subprocess.CREATE_NO_WINDOW,
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            elif sys.platform == "darwin":
                subprocess.run(["osascript", "-e", f"set volume output volume {v}"],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                subprocess.run(["amixer", "-q", "sset", "Master", f"{v}%"],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as exc:
            _comm_log(f"[VOL] Set error: {exc}")

    def _show_apps(self):
        if not self._apps_popup:
            items = [(k.title(), v) for k, v in APPS.items()]
            self._apps_popup = _LauncherPopup("Applications", items)
        btn_g = self.mapToGlobal(QPoint(0, 0))
        self._apps_popup.move(btn_g.x() - 280, btn_g.y())
        self._apps_popup.show_popup()

    def _show_settings(self):
        if not self._stgs_popup:
            items = [(k.title(), f"start {v}") for k, v in SETTINGS_MAP.items()]
            self._stgs_popup = _LauncherPopup("Windows Settings", items)
        btn_g = self.mapToGlobal(QPoint(0, 0))
        self._stgs_popup.move(btn_g.x() - 280, btn_g.y())
        self._stgs_popup.show_popup()

    def _update_ai_label(self):
        if _LOCAL_AI.available:
            active = _get_active_api_configs()
            if active:
                vendor = active[0]["vendor"]
                self._ai_lbl.setText(f"● Cloud API: {vendor} active")
                self._ai_lbl.setStyleSheet("color: #00C8A0; background: transparent;")
            else:
                self._ai_lbl.setText(f"● Local AI: {get_active_model()}")
                self._ai_lbl.setStyleSheet("color: #00A880; background: transparent;")
        else:
            self._ai_lbl.setText("● Local AI: not available")
            self._ai_lbl.setStyleSheet("color: #804040; background: transparent;")

    def _update_network_label(self):
        def _check():
            try:
                socket.create_connection(("8.8.8.8", 53), timeout=2).close()
                return True
            except OSError:
                return False
        connected = _check()
        self._net_lbl.setText(
            "◉ Network: online" if connected else "◌ Network: offline")
        self._net_lbl.setStyleSheet(
            f"color: {'#008060' if connected else '#804040'}; background: transparent;")

    def _refresh_status(self):
        self._update_ai_label()
        self._update_network_label()

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 14, 14)
        bg = QLinearGradient(0, 0, W // 2, H)
        bg.setColorAt(0, QColor(4,  8, 20, 252))
        bg.setColorAt(1, QColor(8, 14, 35, 252))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 80), 1.5))
        p.setBrush(Qt.NoBrush); p.drawPath(path)
        # Corner HUD marks
        pen = QPen(QColor(0, 200, 255, 60), 1.2); p.setPen(pen)
        for (x, y, dx, dy) in [(1,1,10,0),(1,1,0,10),(W-1,1,-10,0),(W-1,1,0,10),
                                 (1,H-1,10,0),(1,H-1,0,-10),(W-1,H-1,-10,0),(W-1,H-1,0,-10)]:
            p.drawLine(x, y, x + dx, y + dy)

    def mousePressEvent(self, e):
        if not self.rect().contains(e.pos()) and self._is_open:
            self._do_hide()



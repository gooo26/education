def _extract_and_write_code(prompt: str, ai_response: str) -> Optional[str]:
    """
    Smart helper to extract source code from LLM responses (JSON ACTION or markdown fences)
    and write it physically to a file inside the user's Desktop/ISHA_Workspace.
    """
    # 1. Try to parse as agent JSON first
    try:
        agent_action = _parse_agent_json(ai_response)
        if agent_action and agent_action.get("category") == "CODE_CREATION":
            det = agent_action.get("action_details", {})
            filename = det.get("filename", "")
            code = det.get("code", "")
            lang = det.get("language", "")
            if code:
                if not filename:
                    ext = ".py"
                    if lang in ("html", "css", "js", "javascript"):
                        ext = f".{lang}" if lang != "javascript" else ".js"
                    filename = f"isha_code{ext}"
                path = _workspace_path(filename)
                with open(path, "w", encoding="utf-8") as f:
                    f.write(code)
                return path
    except Exception as e:
        print(f"[WorkspaceManager] JSON code extraction error: {e}")

    # 2. Try parsing markdown code blocks
    blocks = re.findall(r"```(\w*)\n([\s\S]*?)```", ai_response)
    if blocks:
        # Take the largest block
        lang, code = max(blocks, key=lambda x: len(x[1]))
        lang = lang.lower().strip()
        code = code.strip()

        ext = ".py"
        pl = prompt.lower()
        if "html" in lang or "html" in pl:
            ext = ".html"
        elif "css" in lang or "css" in pl:
            ext = ".css"
        elif "js" in lang or "javascript" in lang or "javascript" in pl or "js" in pl:
            ext = ".js"

        filename = "isha_code" + ext
        if "login" in pl and ext == ".html":
            filename = "login_page.html"
        elif "script" in pl and ext == ".py":
            filename = "isha_script.py"

        path = _workspace_path(filename)
        with open(path, "w", encoding="utf-8") as f:
            f.write(code)
        return path

    # 3. Fallback: if prompt contains code creation keywords and response has code markers
    pl = prompt.lower()
    if any(k in pl for k in ["script", "code", "page", "program"]):
        lines = ai_response.splitlines()
        has_code_markers = any(any(m in line for m in ["import ", "def ", "class ", "<html>", "<!DOCTYPE", "const ", "let ", "function "]) for line in lines)
        if has_code_markers:
            ext = ".py"
            if "html" in pl:
                ext = ".html"
            elif "css" in pl:
                ext = ".css"
            elif "js" in pl or "javascript" in pl:
                ext = ".js"

            filename = "isha_code" + ext
            if "login" in pl and ext == ".html":
                filename = "login_page.html"

            path = _workspace_path(filename)
            with open(path, "w", encoding="utf-8") as f:
                f.write(ai_response.strip())
            return path

    return None



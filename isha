#  §11  GLOBAL HOTKEY LISTENER — Ctrl+Alt+Space
# ══════════════════════════════════════════════════════════════════════════════

class HotkeyListener(QThread):
    hotkey_pressed = pyqtSignal()

    def __init__(self):
        super().__init__()
        self.setObjectName("ISHA-Hotkey")
        self._running = True

    def stop_listener(self):
        self._running = False

    def run(self):
        try:
            import keyboard as kb
            kb.add_hotkey("ctrl+alt+space",
                          lambda: self.hotkey_pressed.emit(), suppress=False)
            while self._running:
                time.sleep(0.3)
            try:
                kb.remove_hotkey("ctrl+alt+space")
            except Exception:
                pass
        except ImportError:
            try:
                from pynput import keyboard as pynput_kb
                def on_press(key):
                    pass
                def on_release(key):
                    pass
                with pynput_kb.Listener(on_press=on_press, on_release=on_release):
                    while self._running:
                        time.sleep(0.3)
            except Exception as exc:
                print(f"[HOTKEY] Listener failed: {exc}")



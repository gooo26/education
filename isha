class HistoryManager:
    _MAX_SESSIONS = 200
    _MAX_ENTRIES_PER_SESSION = 500

    def __init__(self):
        self._lock     = threading.Lock()
        self._data     = self._load()
        self._cur_sid  = self._new_session_id()
        self._entry_id = 1

    def _load(self) -> dict:
        if HISTORY_FILE.exists():
            try:
                return json.loads(HISTORY_FILE.read_text("utf-8"))
            except Exception:
                pass
        return {"sessions": []}

    def _save(self):
        try:
            HISTORY_FILE.write_text(
                json.dumps(self._data, indent=2, ensure_ascii=False), "utf-8")
        except Exception as exc:
            print(f"[HIST] Save failed: {exc}")

    def _new_session_id(self) -> str:
        return datetime.now().strftime("%Y-%m-%d_%H-%M-%S")

    def _get_or_create_session(self) -> dict:
        sessions = self._data.setdefault("sessions", [])
        for s in sessions:
            if s["session_id"] == self._cur_sid:
                return s
        new_session = {
            "session_id": self._cur_sid,
            "date":       datetime.now().strftime("%Y-%m-%d"),
            "started":    datetime.now().isoformat(timespec="seconds"),
            "entries":    [],
        }
        sessions.append(new_session)
        if len(sessions) > self._MAX_SESSIONS:
            self._data["sessions"] = sessions[-self._MAX_SESSIONS:]
        return new_session

    def log(self, user_text: str, isha_reply: str, intent: str = ""):
        with self._lock:
            session = self._get_or_create_session()
            entries = session.setdefault("entries", [])
            entry   = {
                "id":     self._entry_id,
                "ts":     datetime.now().isoformat(timespec="seconds"),
                "user":   user_text,
                "isha":   isha_reply,
                "intent": intent,
            }
            entries.append(entry)
            self._entry_id += 1
            if len(entries) > self._MAX_ENTRIES_PER_SESSION:
                session["entries"] = entries[-self._MAX_ENTRIES_PER_SESSION:]
            self._save()

    def get_all_sessions(self) -> List[dict]:
        with self._lock:
            return list(self._data.get("sessions", []))

    def get_session(self, session_id: str) -> Optional[dict]:
        with self._lock:
            for s in self._data.get("sessions", []):
                if s["session_id"] == session_id:
                    return s
        return None

    def clear_all(self):
        with self._lock:
            self._data = {"sessions": []}
            self._cur_sid  = self._new_session_id()
            self._entry_id = 1
            self._save()

    def clear_session(self, session_id: str):
        with self._lock:
            self._data["sessions"] = [
                s for s in self._data.get("sessions", [])
                if s["session_id"] != session_id
            ]
            self._save()

    def entry_count(self) -> int:
        with self._lock:
            return sum(len(s.get("entries", []))
                       for s in self._data.get("sessions", []))



def _news_sync(query: str = "") -> str:
    try:
        import requests, xml.etree.ElementTree as ET
        gnews_key = _API_STORE.get("gnews", "")
        if gnews_key:
            url  = (f"https://gnews.io/api/v4/top-headlines"
                    f"?lang=en&max=5&token={gnews_key}")
            resp = requests.get(url, timeout=8)
            data = resp.json()
            articles = data.get("articles", [])
            if articles:
                headlines = [f"{i+1}. {a['title']}" for i, a in enumerate(articles[:5])]
                return "Top headlines: " + " | ".join(headlines)
        rss_url = "https://news.google.com/rss?hl=en-IN&gl=IN&ceid=IN:en"
        resp    = requests.get(rss_url, timeout=8,
                    headers={"User-Agent": "Mozilla/5.0 (compatible; ISHA/10.0)"})
        root    = ET.fromstring(resp.content)
        items   = root.findall(".//item")[:5]
        headlines = []
        for i, item in enumerate(items):
            title = item.findtext("title", "").strip()
            title = re.sub(r"\s*-\s*[^-]{2,40}$", "", title).strip()
            if title:
                headlines.append(f"{i+1}. {title}")
        return ("Today's top headlines: " + " | ".join(headlines)
                if headlines else "Could not fetch news. Please try again later.")

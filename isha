class SplashScreen(QWidget):
    done = pyqtSignal()

    def __init__(self):
        super().__init__()
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self.setFixedSize(400, 210)
        sc = QApplication.primaryScreen().geometry()
        self.move((sc.width() - 400) // 2, (sc.height() - 210) // 2)
        self._prog = 0.0
        glow = QGraphicsDropShadowEffect(self)
        glow.setBlurRadius(50); glow.setOffset(0, 0)
        glow.setColor(QColor(0, 200, 255, 140))
        self.setGraphicsEffect(glow)
        self._pt = QTimer(self); self._pt.timeout.connect(self._tick)
        self._pt.start(22)
        fa = QPropertyAnimation(self, b"windowOpacity")
        fa.setStartValue(0.0); fa.setEndValue(1.0); fa.setDuration(500)
        fa.setEasingCurve(QEasingCurve.OutCubic); fa.start()
        self._fa = fa

    def _tick(self):
        self._prog = min(1.0, self._prog + 0.012)
        self.update()
        if self._prog >= 1.0:
            self._pt.stop()
            QTimer.singleShot(300, self._finish)

    def _finish(self):
        fa = QPropertyAnimation(self, b"windowOpacity")
        fa.setStartValue(1.0); fa.setEndValue(0.0); fa.setDuration(400)
        fa.finished.connect(self.close); fa.finished.connect(self.done); fa.start()
        self._fa2 = fa

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 20, 20)
        bg = QLinearGradient(0, 0, W, H)
        bg.setColorAt(0, QColor(4,  8, 20, 252))
        bg.setColorAt(1, QColor(8, 14, 35, 252))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 240, 255, 150), 2.0)); p.setBrush(Qt.NoBrush)
        p.drawPath(path)
        pen_c = QPen(QColor(0, 240, 255, 120), 1.5); p.setPen(pen_c)
        for (x, y, dx, dy) in [(2,2,12,0),(2,2,0,12),(W-2,2,-12,0),(W-2,2,0,12),
                                 (2,H-2,12,0),(2,H-2,0,-12),(W-2,H-2,-12,0),(W-2,H-2,0,-12)]:
            p.drawLine(x, y, x + dx, y + dy)
        p.setFont(QFont("Segoe UI Light", 48)); p.setPen(QColor(0, 240, 255))
        p.drawText(QRectF(0, 16, W, 74), Qt.AlignCenter, "ISHA")
        p.setFont(QFont("Segoe UI", 9)); p.setPen(QColor(0, 150, 180))
        p.drawText(QRectF(0, 80, W, 24), Qt.AlignCenter,
                   "Intelligent System for Human Assistance  v12.0")
        p.setPen(QPen(QColor(0, 120, 160, 80), 1))
        p.drawLine(QPointF(W // 2 - 100, 112), QPointF(W // 2 + 100, 112))
        bw, bh, bx, by = 260, 4, (W - 260) // 2, 134
        p.setPen(Qt.NoPen); p.setBrush(QColor(0, 20, 35))
        p.drawRoundedRect(QRectF(bx, by, bw, bh), 2, 2)
        fill = QLinearGradient(bx, by, bx + bw, by)
        fill.setColorAt(0, QColor(0, 200, 255)); fill.setColorAt(1, QColor(0, 120, 200))
        p.setBrush(QBrush(fill))
        p.drawRoundedRect(QRectF(bx, by, int(bw * self._prog), bh), 2, 2)
        if self._prog > 0.05:
            gx = bx + int(bw * self._prog)
            g  = QRadialGradient(gx, by + 2, 12)
            g.setColorAt(0, QColor(0, 240, 255, 180)); g.setColorAt(1, QColor(0, 0, 0, 0))
            p.setBrush(QBrush(g)); p.drawEllipse(QPointF(gx, by + 2), 12, 8)
        steps = ["Initializing…", "Loading models…", "Probing AI…", "Ready!"]
        idx   = min(int(self._prog * len(steps)), len(steps) - 1)
        p.setFont(QFont("Segoe UI", 8)); p.setPen(QColor(0, 120, 160))
        p.drawText(QRectF(0, 148, W, 26), Qt.AlignCenter, steps[idx])



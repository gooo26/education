# Thread-safe log queue consumed by CommDockWindow
_COMM_LOG_QUEUE : queue.Queue = queue.Queue(maxsize=2000)


def _comm_log(msg: str):
    """Post a message to the communication dock (thread-safe)."""
    ts = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    try:
        _COMM_LOG_QUEUE.put_nowait(f"[{ts}]  {msg}")
    except queue.Full:
        pass


class CommDockWindow(QWidget):
    """
    Live Communication Console — real-time log streaming via QTimer polling.
    Signal slots fully wired. Never freezes the interface.
    """
    _new_log = pyqtSignal(str)   # cross-thread safe delivery

    def __init__(self, parent=None):
        super().__init__(parent, Qt.Tool | Qt.FramelessWindowHint |
                         Qt.WindowStaysOnTopHint)
        self.setAttribute(Qt.WA_TranslucentBackground, True)
        self.setFixedSize(540, 340)
        self._drag_pos = None

        self._new_log.connect(self._append_log, Qt.QueuedConnection)

        self._build()

        self._poll_timer = QTimer(self)
        self._poll_timer.timeout.connect(self._poll_queue)
        self._poll_timer.start(50)   # 20 Hz polling — real-time feel

    def _build(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(12, 12, 12, 12)
        root.setSpacing(6)

        # Build log area FIRST so clear_btn can safely reference it (v11 fix)
        self._log_area = QTextEdit()
        self._log_area.setReadOnly(True)
        self._log_area.setFont(QFont("Consolas", 8))
        self._log_area.setStyleSheet("""
            QTextEdit {
                background: rgba(2, 6, 15, 230); color: #58A8C0;
                border: 1px solid rgba(0,160,200,60); border-radius: 8px;
                padding: 6px;
            }
            QScrollBar:vertical {
                background: rgba(0,10,20,80); width: 4px; border-radius: 2px;
            }
            QScrollBar::handle:vertical {
                background: rgba(0,200,255,100); border-radius: 2px;
            }
            QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
        """)

        hdr_row = QHBoxLayout()
        title = QLabel("● ISHA Communication Dock")
        title.setFont(QFont("Segoe UI Semibold", 10))
        title.setStyleSheet("color: #00F0FF; background: transparent;")
        hdr_row.addWidget(title)
        hdr_row.addStretch()
        clear_btn = QPushButton("Clear")
        clear_btn.setFixedSize(52, 22)
        clear_btn.setStyleSheet("""
            QPushButton { background: rgba(0,40,60,200); color: #00C8E8;
                border: 1px solid rgba(0,180,240,60); border-radius: 5px; font-size: 8pt; }
            QPushButton:hover { background: rgba(0,60,90,220); border: 1px solid rgb(0,240,255); color: #FFFFFF; }
            QPushButton:pressed { background: rgba(0,90,130,240); }
        """)
        clear_btn.clicked.connect(self._log_area.clear)
        hdr_row.addWidget(clear_btn)
        close_btn = QPushButton("✕")
        close_btn.setFixedSize(22, 22)
        close_btn.setStyleSheet("""
            QPushButton { background: rgba(60,0,0,180); color: #FF4040;
                border: 1px solid rgba(255,60,60,60); border-radius: 5px; font-size: 9pt; }
            QPushButton:hover { background: rgba(100,0,0,220); border: 1px solid rgb(255,80,80); color: #FFFFFF; }
            QPushButton:pressed { background: rgba(150,0,0,240); }
        """)
        close_btn.clicked.connect(self.hide)
        hdr_row.addWidget(close_btn)
        root.addLayout(hdr_row)
        root.addWidget(self._log_area)

        self._append_log("=== ISHA v13 Communication Dock Initialized ===")

    def _poll_queue(self):
        """Poll the global log queue and emit signal for each entry."""
        batch = []
        for _ in range(50):   # drain up to 50 messages per tick
            try:
                msg = _COMM_LOG_QUEUE.get_nowait()
                batch.append(msg)
            except queue.Empty:
                break
        for msg in batch:
            self._new_log.emit(msg)

    def _append_log(self, text: str):
        """Append text to log area and auto-scroll — MUST be called on GUI thread."""
        color = "#58A8C0"  # default cyberpunk blue
        if "⚠️" in text or "ALERT" in text or "WARNING" in text or "error" in text.lower() or "fail" in text.lower():
            color = "#FF3366"  # Cyberpunk neon pink/red
        elif "Done" in text or "success" in text.lower() or "AGENT DONE" in text or "Zipped" in text or "Unzipped" in text:
            color = "#00FF66"  # Cyberpunk neon green
        self._log_area.append(f'<span style="color:{color};">{html.escape(text)}</span>')
        sb = self._log_area.verticalScrollBar()
        QTimer.singleShot(20, lambda: sb.setValue(sb.maximum()))

    def paintEvent(self, e):
        p = QPainter(self); p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, W, H), 14, 14)
        bg = QLinearGradient(0, 0, W, H)
        bg.setColorAt(0, QColor(3, 6, 16, 252))
        bg.setColorAt(1, QColor(6, 10, 24, 252))
        p.fillPath(path, QBrush(bg))
        p.setPen(QPen(QColor(0, 200, 255, 80), 1.5))
        p.setBrush(Qt.NoBrush); p.drawPath(path)
        # HUD corner marks
        pen = QPen(QColor(0, 200, 255, 80), 1.2); p.setPen(pen)
        for (x, y, dx, dy) in [(1,1,12,0),(1,1,0,12),(W-1,1,-12,0),(W-1,1,0,12),
                                 (1,H-1,12,0),(1,H-1,0,-12),(W-1,H-1,-12,0),(W-1,H-1,0,-12)]:
            p.drawLine(x, y, x + dx, y + dy)

    def mousePressEvent(self, e):
        if e.button() == Qt.LeftButton:
            self._drag_pos = e.globalPos() - self.frameGeometry().topLeft()

    def mouseMoveEvent(self, e):
        if e.buttons() == Qt.LeftButton and self._drag_pos:
            self.move(e.globalPos() - self._drag_pos)

    def mouseReleaseEvent(self, e):
        self._drag_pos = None


